generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL") // ★これが必要です
}

// 3. モデル定義（今回投入したテーブル構造に合わせます）
model Prefecture {
  id        Int     @id
  name      String  @unique
  name_kana String
  name_en   String? @db.VarChar(50)
  areas     Area[] // リレーション
  prohibitedProperties ProhibitedProperty[]
  partnerAreaPrices    PartnerAreaPrice[]

  @@map("prefectures") // 実際のテーブル名が複数形なら合わせる
}

model City {
  id                    Int                    @id
  prefecture_id         Int
  code                  String                 @unique
  name                  String
  name_kana             String
  name_en               String?                @db.VarChar(100)
  areas                 Area[] // リレーション
  distributionSchedules DistributionSchedule[]
  prohibitedProperties  ProhibitedProperty[]
  partnerAreaPrices     PartnerAreaPrice[]

  @@map("cities")
}

// エリアランクマスター
model AreaRank {
  id               Int     @id @default(autoincrement())
  name             String  @unique @db.VarChar(50)
  postingUnitPrice Float   @default(5.0) @map("posting_unit_price")
  description      String? @db.VarChar(200)

  areas            Area[]

  @@map("area_ranks")
}

model Area {
  id                  Int      @id @default(autoincrement())
  prefecture_id       Int
  city_id             Int
  address_code        String   @unique
  town_name           String
  chome_name          String
  name_en             String?  @db.VarChar(200)
  boundary_geojson    String?  @db.LongText // ｜で繋いだデータは長くなるのでLongText推奨
  door_to_door_count  Int      @default(0)
  multi_family_count  Int      @default(0)
  posting_cap_raw     Int      @default(0)
  posting_cap_with_ng Int      @default(0)
  area_rank_id        Int?     @map("area_rank_id")
  is_client_visible   Int      @default(1)

  // リレーションの定義
  prefecture            Prefecture             @relation(fields: [prefecture_id], references: [id])
  city                  City                   @relation(fields: [city_id], references: [id])
  areaRank              AreaRank?              @relation(fields: [area_rank_id], references: [id])
  distributionSchedules DistributionSchedule[]
  orderDistributions OrderDistributionArea[]
  prohibitedProperties ProhibitedProperty[]
  partnerCoverageAreas PartnerCoverageArea[]

  @@map("areas")
}

enum Gender {
  male
  female
  other
  unknown
}

// --- 新規: 社員の階級 (等級) ---
enum EmployeeRank {
  EXECUTIVE   @map("役員")
  DIRECTOR    @map("本部長・事業部長")
  MANAGER     @map("マネージャー")
  LEADER      @map("リーダー")
  ASSOCIATE   @map("アソシエイト(一般)")
}

model Employee {
  id             Int       @id @default(autoincrement())
  passwordHash   String    @map("password_hash") @db.VarChar(255)

  // ★ 追加: 社員コード
  employeeCode   String?   @unique @map("employee_code") @db.VarChar(50)
  
  lastNameJa     String    @map("last_name_ja") @db.VarChar(50)
  firstNameJa    String    @map("first_name_ja") @db.VarChar(50)
  lastNameEn     String?   @map("last_name_en") @db.VarChar(50)
  firstNameEn    String?   @map("first_name_en") @db.VarChar(50)
  // ★ 追加: カナ氏名
  lastNameKana   String?   @map("last_name_kana") @db.VarChar(50)
  firstNameKana  String?   @map("first_name_kana") @db.VarChar(50)

  // ★ 追加: 誕生日と性別
  birthday       DateTime? @db.Date
  gender         Gender    @default(unknown)
  
  email          String    @unique @db.VarChar(100)
  personalEmail       String?   @unique @map("personal_email") @db.VarChar(100)
  workspaceNotifiedAt DateTime? @map("workspace_notified_at")
  phone               String?   @db.VarChar(20)
  postalCode          String?   @map("postal_code") @db.VarChar(8)
  address             String?   @db.Text
  buildingName        String?   @map("building_name") @db.VarChar(100)

  // ============================
  // ★ 新規追加: 組織・役職・権限情報
  // ============================
  
  // 1. 支店 (既存のBranchテーブルと紐付け)
  branchId       Int?          @map("branch_id")
  branch         Branch?       @relation("BranchEmployees", fields: [branchId], references: [id])
  
  // 2. 部署
  departmentId   Int?          @map("department_id")
  department     Department?   @relation(fields: [departmentId], references: [id])
  
  // 3. 階級 (Enum)
  rank           EmployeeRank  @default(ASSOCIATE)
  
  // 4. 職種 (テキスト)
  jobTitle       String?       @map("job_title") @db.VarChar(100)

  // ★ 追加: 国マスタとの紐付け
  countryId      Int?          @map("country_id")
  country        Country?      @relation(fields: [countryId], references: [id])

  // ★ ビザ・在留カード・銀行カード
  visaTypeId                         Int?      @map("visa_type_id")
  visaType                           VisaType? @relation(fields: [visaTypeId], references: [id])
  visaExpiryDate                     DateTime? @map("visa_expiry_date") @db.Date

  hasResidenceCard                   Boolean   @default(false) @map("has_residence_card")
  residenceCardFrontUrl              String?   @map("residence_card_front_url") @db.Text
  residenceCardBackUrl               String?   @map("residence_card_back_url") @db.Text
  residenceCardVerificationStatus    ResidenceCardVerificationStatus? @map("residence_card_verification_status")
  residenceCardVerificationResult    Json?     @map("residence_card_verification_result")
  residenceCardVerifiedAt            DateTime? @map("residence_card_verified_at")

  bankCardImageUrl                   String?   @map("bank_card_image_url") @db.Text

  // ============================

  // ------------------------------------------------
  // ★ ここに追加: 直属の上司 (自己参照リレーション)
  // ------------------------------------------------
  managerId      Int?          @map("manager_id")
  manager        Employee?     @relation("EmployeeToManager", fields: [managerId], references: [id])
  subordinates   Employee[]    @relation("EmployeeToManager")

  // ★ 以下の1行を追加 (勤怠の承認者としての逆参照)
  approvedAttendances Attendance[] @relation("AttendanceApprover")

  avatarUrl      String?       @map("avatar_url") @db.Text
  language       String?       @default("ja") @db.VarChar(5)

  isActive            Boolean   @default(true) @map("is_active")
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  hireDate       DateTime? @map("hire_date") @db.Date
  resignationDate DateTime? @map("resignation_date") @db.Date
  
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  // 各種リレーション (既存のものそのまま残す)
  customers          Customer[]
  orders             Order[]
  approvals          OrderApproval[]
  designs            OrderDesign[]
  flyerTransactions  FlyerTransaction[]
  financial          EmployeeFinancial?
  employmentType EmploymentType @default(FULL_TIME) @map("employment_type")
  attendances        Attendance[]
  expenses           Expense[]
  approvedExpenses   Expense[]    @relation("ExpenseApprover") // 自分が承認した経費
  paidLeaveLedgers   PaidLeaveLedger[]
  roles EmployeeRole[]
  payrollRecords     PayrollRecord[]

  // ★ 支店のマネージャーとしての逆参照 (エラー解消のキモ)
  managedBranches1   Branch[] @relation("BranchManager1")
  managedBranches2   Branch[] @relation("BranchManager2")
  managedBranches3   Branch[] @relation("BranchManager3")
  managedBranches4   Branch[] @relation("BranchManager4")

  // CRM
  activities     CustomerActivity[] @relation("ActivityEmployee")
  assignedTasks    Task[]             @relation("TaskAssignee")
  createdTasks     Task[]             @relation("TaskCreator")
  taskAssignments  TaskAssignee[]     @relation("TaskAssigneeEmployee")
  leads          Lead[]

  announcements  Announcement[]
  announcementReads AnnouncementRead[]

  passwordResetTokens PasswordResetToken[]

  // クレーム管理
  assignedComplaints   Complaint[]         @relation("ComplaintAssignee")
  complaintResponses   ComplaintResponse[] @relation("ComplaintResponder")

  // アプリ配信
  appDistributionsSent AppDistributionLog[] @relation("AppDistributionSender")

  // 面接担当スロット
  interviewSlots              InterviewSlot[]      @relation("InterviewerSlots")
  defaultInterviewSlots       DefaultInterviewSlot[] @relation("DefaultSlotInterviewer")

  // アラート
  resolvedAlerts              Alert[]              @relation("AlertResolver")

  // 通知受信
  receivedNotifications       AdminNotification[]  @relation("NotificationRecipient")

  // 巡回記録（巡回員として）
  fieldInspections            FieldInspection[]

  // パートナーインシデント解決
  resolvedPartnerIncidents    PartnerIncident[] @relation("PartnerIncidentResolver")
  complianceChecks            DistributionSchedule[] @relation("ComplianceChecker")

  // 中継/回収ドライバー
  relayTasks                  RelayTask[] @relation("RelayDriver")

  // ピッキング照合
  pickingAsPicker             PickingVerification[] @relation("PickingPicker")
  pickingAsChecker            PickingVerification[] @relation("PickingChecker")

  @@map("employees")
}

// --- パスワードリセットトークン (ワンタイム) ---
model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  token      String    @unique @db.VarChar(64)
  employeeId Int       @map("employee_id")
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

// --- 雇用形態 ---
enum EmploymentType {
  FULL_TIME
  PART_TIME
  OUTSOURCE
}

// --- 給与形態 ---
enum SalaryType {
  HOURLY      @map("時給")
  DAILY       @map("日給")
  MONTHLY     @map("月給")
}

// --- 社員向け支払方法 ---
enum EmployeePaymentMethod {
  CASH          @map("現金手渡し")
  BANK_TRANSFER @map("銀行振込")
}

// --- 支払サイクル ---
enum PaymentCycle {
  DAILY       @map("日払い")
  WEEKLY      @map("週払い")
  MONTHLY     @map("月払い")
}

// --- 銀行マスタ ---
model Bank {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.VarChar(20)    // 銀行コード (例: 0001)
  name      String   @db.VarChar(100)           // 銀行名 (例: みずほ銀行)
  nameKana  String?  @map("name_kana") @db.VarChar(100)
  sortOrder Int      @default(100) @map("sort_order")

  financials EmployeeFinancial[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("banks")
}

enum BankAccountType {
  ORDINARY  @map("普通")
  CURRENT   @map("当座")
  SAVINGS   @map("貯蓄")
}

model EmployeeFinancial {
  id                Int              @id @default(autoincrement())
  
  // Employeeとの1対1の紐付け
  employeeId        Int              @unique @map("employee_id")
  employee          Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // --- 給与・契約関連 ---
  salaryType        SalaryType            @default(MONTHLY) @map("salary_type")
  
  baseSalary        Int?                  @map("base_salary")        // 月給
  hourlyRate        Int?                  @map("hourly_rate")        // 時給
  dailyRate         Int?                  @map("daily_rate")         // 日給

  defaultStartTime  String?               @default("09:00") @map("default_start_time") @db.VarChar(5)
  defaultEndTime    String?               @default("18:00") @map("default_end_time") @db.VarChar(5)
  defaultBreakMins  Int?                  @default(60) @map("default_break_mins")
  // 通常出勤曜日 例: "1,2,3,4,5" = 月〜金 (1=月, 2=火, ... 7=日)
  workingWeekdays   String?               @default("1,2,3,4,5") @map("working_weekdays") @db.VarChar(20)

  paymentMethod     EmployeePaymentMethod @default(BANK_TRANSFER) @map("payment_method")
  paymentCycle      PaymentCycle          @default(MONTHLY) @map("payment_cycle")
  paymentDay        Int?                  @map("payment_day")        // 月払いの場合の支払日 (例: 25。月末なら99などルール決め)

  transportationFee String?               @map("transportation_fee") // 交通費の規定
  allowance         Int?                  @default(0)                // 役職手当などの固定手当
  paidLeaveBalance  Float?                @default(0) @map("paid_leave_balance")
  
  // --- 控除・保険関連 (給与計算用) ---
  healthInsurance   Int?                  @default(0) @map("health_insurance")       // 健康保険料
  pensionInsurance  Int?                  @default(0) @map("pension_insurance")      // 厚生年金保険料
  employmentInsurance Int?                @default(0) @map("employment_insurance")   // 雇用保険料
  workerAccidentInsurance Int?            @default(0) @map("worker_accident_insurance") // 労災保険料(基本は会社負担ですが一応)
  residentTax       Int?                  @default(0) @map("resident_tax")           // 住民税
  incomeTax         Int?                  @default(0) @map("income_tax")             // 所得税(固定の場合など)

  // --- 銀行口座情報 ---
  // ★ 文字列入力から、Bankマスタへの紐付けに変更
  bankId            Int?                  @map("bank_id")
  bank              Bank?                 @relation(fields: [bankId], references: [id])
  
  branchName        String?               @map("branch_name") @db.VarChar(100)      // 支店名
  branchCode        String?               @map("branch_code") @db.VarChar(20)       // 支店コード
  accountType       BankAccountType?      @map("account_type")                      // 口座種別(普通/当座)
  accountNumber     String?               @map("account_number") @db.VarChar(20)    // 口座番号
  accountName       String?               @map("account_name") @db.VarChar(100)     // 口座名義
  accountNameKana   String?               @map("account_name_kana") @db.VarChar(100)// 口座名義(カナ)

  note              String?               @db.Text                                  // 備考

  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @default(now()) @updatedAt @map("updated_at")

  @@map("employee_financials")
}

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique @db.Char(2) // 'JP', 'US' など
  name      String   @db.VarChar(50) // '日本'
  nameEn    String?  @map("name_en") @db.VarChar(50) // 'Japan'
  aliases   String?  @db.Text // カンマ区切り別名: "韓国,大韓民国,Korea,South Korea"
  sortOrder Int      @default(100) @map("sort_order") // 表示順（小さいほど上位）
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  employees    Employee[]
  distributors FlyerDistributor[]
  applicants   Applicant[]

  @@map("countries")
}

model Department {
  id        Int      @id @default(autoincrement())
  code      String?  @unique @db.VarChar(20)
  name      String   @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション
  employees     Employee[]
  taskAssignees TaskAssignee[]

  @@map("departments")
}

// --- システム設定（キー・バリュー形式） ---
model SystemSetting {
  key       String   @id @db.VarChar(50)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model Role {
  id              Int      @id @default(autoincrement())
  code            String   @unique @db.VarChar(50) // ★追加: 'SUPER_ADMIN', 'HR_ADMIN' など
  name            String   @db.VarChar(50)         // 'スーパー管理者', '人事管理者' など
  permissionLevel String?  @map("permission_level") @db.VarChar(20) // ※任意に変更
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // ★ 変更: 中間テーブルとのリレーション
  employees       EmployeeRole[]

  @@map("roles")
}

// 社員とロールを紐づける中間テーブル (1人が複数ロールを持てる)
model EmployeeRole {
  id         Int      @id @default(autoincrement())
  employeeId Int      @map("employee_id")
  roleId     Int      @map("role_id")
  
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([employeeId, roleId]) // 同じロールを2重に登録できないようにする
  @@map("employee_roles")
}

// --- 顧客ステータス (Enum) ---
enum CustomerStatus {
  VALID   @map("有効")
  INVALID @map("無効")
}

// ★ 追加: 顧客タイプ (法人 / 個人)
enum CustomerType {
  COMPANY     @map("法人")
  INDIVIDUAL  @map("個人")
}

// 流入経路
enum AcquisitionChannel {
  EC
  SALES
  REFERRAL
  INQUIRY
}

// 見込み客ステージ
enum LeadStage {
  APPROACH     // アプローチ中
  PROPOSAL     // 提案中
  QUOTATION    // 見積中
  NEGOTIATION  // 交渉中
  LOST         // 失注
  ON_HOLD      // 保留
}

// --- 顧客マスタ (Customers) ---
model Customer {
  id           Int    @id @default(autoincrement())
  customerCode String @unique @map("customer_code") @db.VarChar(20)
  customerType CustomerType @default(COMPANY) @map("customer_type")

  // 人・組織との紐付け
  salesRepId        Int? @map("sales_rep_id")
  billingCustomerId Int? @map("billing_customer_id")
  parentCustomerId  Int? @map("parent_customer_id")
  industryId        Int? @map("industry_id")

  // 基本情報
  name     String @db.VarChar(100)
  nameKana String? @map("name_kana") @db.VarChar(100)

  // 請求・インボイス関連
  invoiceRegistrationNumber String? @map("invoice_registration_number") @db.VarChar(14)
  billingCutoffDay          Int?    @map("billing_cutoff_day") @db.TinyInt
  paymentMonthDelay         Int?    @default(1) @map("payment_month_delay") @db.TinyInt
  paymentDay                Int?    @map("payment_day") @db.TinyInt

  // 連絡先
  postalCode      String? @map("postal_code") @db.VarChar(8)
  address         String? @db.VarChar(255) // 住所
  addressBuilding String? @map("address_building") @db.VarChar(255) // 建物名以降 (DDLの2つ目のaddress)
  phone           String? @db.VarChar(20)
  fax             String? @db.VarChar(20)

  // マーケティング
  acquisitionChannel AcquisitionChannel? @map("acquisition_channel")
  campaignId         Int?                @map("campaign_id")

  // システム制御
  status    CustomerStatus @default(VALID)
  note      String?        @db.Text
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  deletedAt DateTime?      @map("deleted_at")
  wantsNewsletter Boolean @default(true)
  defaultPaymentMethod String? @map("default_payment_method") @db.VarChar(30)

  // --- リレーション定義 ---

  // 1. 担当営業 (Employeeとの紐付け)
  salesRep Employee? @relation(fields: [salesRepId], references: [id])

  // 2. 請求先顧客 (自己参照: 親)
  billingCustomer   Customer?  @relation("BillingRelation", fields: [billingCustomerId], references: [id])
  //    請求先として自身を参照している顧客 (自己参照: 子)
  billedByCustomers Customer[] @relation("BillingRelation")

  // 3. 親顧客 (自己参照: 親)
  parentCustomer Customer?  @relation("ParentRelation", fields: [parentCustomerId], references: [id])
  //    子顧客 (自己参照: 子)
  childCustomers Customer[] @relation("ParentRelation")

  // 4. 業種
  industry Industry? @relation(fields: [industryId], references: [id])

  // 5. 担当者マスタ
  contacts CustomerContact[]

  // リレーション（この顧客の配布アイテム明細）
  distributionItems DistributionItem[]

  flyers Flyer[]
  orders   Order[]
  notifications   Notification[] // ★これを追加
  qrCodes  QrCode[]
  deliveryAddresses CustomerDeliveryAddress[]
  activities CustomerActivity[]
  tasks          Task[]
  taskTemplates  TaskTemplate[]
  campaign       Campaign? @relation(fields: [campaignId], references: [id])
  leads      Lead[]    @relation("LeadConversion")
  billingStatements BillingStatement[]
  complaints           Complaint[]
  prohibitedProperties ProhibitedProperty[]

  @@index([name])
  @@index([salesRepId])
  @@index([status])
  @@map("customers")
}

// --- 顧客担当者マスタ (CustomerContacts) ---
model CustomerContact {
  id         Int @id @default(autoincrement())
  customerId Int @map("customer_id")

  // 担当者個人情報
  lastName      String  @map("last_name") @db.VarChar(50)
  firstName     String  @map("first_name") @db.VarChar(50)
  lastNameKana  String? @map("last_name_kana") @db.VarChar(50)
  firstNameKana String? @map("first_name_kana") @db.VarChar(50)
  department  String? @db.VarChar(50)
  position    String? @db.VarChar(50)
  email       String? @db.VarChar(100)
  mobilePhone String? @map("mobile_phone") @db.VarChar(20)
  directLine  String? @map("direct_line") @db.VarChar(20)

  // 役割フラグ
  isPrimary        Boolean @default(false) @map("is_primary")
  isBillingContact Boolean @default(false) @map("is_billing_contact")
  notifyOrderStatus Boolean @default(true) @map("notify_order_status")
  notifyQrScan      Boolean @default(true) @map("notify_qr_scan")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // デフォルト納品先住所
  defaultDeliveryAddressId Int?                     @map("default_delivery_address_id")
  defaultDeliveryAddress   CustomerDeliveryAddress?  @relation("ContactDefaultDeliveryAddress", fields: [defaultDeliveryAddressId], references: [id], onDelete: SetNull)

  // リレーション
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orderContacts OrderContact[]
  passwordHash      String?  @map("password_hash") @db.VarChar(255) // クライアントログイン用パスワード
  lastLoginAt       DateTime? @map("last_login_at") @db.DateTime(0)
  mustChangePassword Boolean  @default(false) @map("must_change_password")

  @@map("customer_contacts")
}

// --- 顧客納品先住所マスタ (CustomerDeliveryAddresses) ---
model CustomerDeliveryAddress {
  id               Int      @id @default(autoincrement())
  customerId       Int      @map("customer_id")
  label            String   @db.VarChar(100)  // "本社", "支社A" 等
  organizationName String?  @map("organization_name") @db.VarChar(100) // 組織名
  recipientName    String?  @map("recipient_name") @db.VarChar(100)    // 宛先名
  postalCode       String?  @map("postal_code") @db.VarChar(8)
  address          String?  @db.VarChar(255)
  addressBuilding  String?  @map("address_building") @db.VarChar(255)
  phone            String?  @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  customer           Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  defaultForContacts CustomerContact[] @relation("ContactDefaultDeliveryAddress")

  @@map("customer_delivery_addresses")
}

// --- チラシ配布員マスタ (Flyer Distributors) ---
model FlyerDistributor {
  id       Int     @id @default(autoincrement())
  branchId Int?    @map("branch_id")
  branch   Branch? @relation(fields: [branchId], references: [id])
  // ▲ ここまで ▲

  // 国籍
  countryId Int?     @map("country_id")
  country   Country? @relation(fields: [countryId], references: [id])

  // 在留資格
  visaTypeId Int?      @map("visa_type_id")
  visaType   VisaType? @relation(fields: [visaTypeId], references: [id])

  // 基本情報
  staffId      String    @unique @map("staff_id") @db.VarChar(20)
  name         String    @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  email        String?   @db.VarChar(100)
  birthday     DateTime? @db.Date
  gender       String?   @db.VarChar(10)
  postalCode   String?   @map("postal_code") @db.VarChar(8)
  address      String?   @db.Text
  buildingName String?   @map("building_name") @db.VarChar(100)

  // 認証
  passwordHash   String?  @map("password_hash") @db.VarChar(100)
  isPasswordTemp Boolean  @default(true) @map("is_password_temp") // 初回ログイン時に変更必須
  language       String   @default("ja") @db.VarChar(5) // ポータル言語: "ja" or "en"
  hasSeenOnboarding Boolean @default(false) @map("has_seen_onboarding")

  // 在留資格・契約情報
  visaExpiryDate        DateTime? @map("visa_expiry_date") @db.Date
  hasAgreedPersonalInfo Boolean   @default(false) @map("has_agreed_personal_info") // 個人情報同意 (○)
  hasSignedContract     Boolean   @default(false) @map("has_signed_contract") // 業務委託締結 (○)
  contractStatus        String?   @map("contract_status") @db.VarChar(20) // UNSIGNED / SENT / SIGNED
  contractDate          DateTime? @map("contract_date") // 署名完了日
  contractPdfUrl        String?   @map("contract_pdf_url") @db.Text // S3上の署名済みPDF URL
  docusealSubmissionId  Int?      @map("docuseal_submission_id") // DocuSeal submission ID
  docusealSubmitterId   Int?      @map("docuseal_submitter_id") // DocuSeal submitter ID
  hasResidenceCard      Boolean   @default(false) @map("has_residence_card") // 在留カード (○)
  residenceCardFrontUrl String?   @map("residence_card_front_url") @db.Text // 在留カード表面画像URL
  residenceCardBackUrl  String?   @map("residence_card_back_url") @db.Text // 在留カード裏面画像URL
  residenceCardVerificationStatus  ResidenceCardVerificationStatus? @map("residence_card_verification_status")
  residenceCardVerificationResult  Json?                            @map("residence_card_verification_result")
  residenceCardVerifiedAt          DateTime?                        @map("residence_card_verified_at")

  // 在籍情報
  joinDate    DateTime? @map("join_date") @db.Date // 入社日
  leaveDate   DateTime? @map("leave_date") @db.Date // 退社日
  leaveReason String?   @map("leave_reason") @db.Text // 退社理由
  leaveType   String?   @map("leave_type") @db.VarChar(30) // 退職タイプ (RESIGNATION/TERMINATED/NO_CONTACT)

  // 支払い・口座情報
  paymentMethod       String? @map("payment_method") @db.VarChar(20) // 支払い方法 (現金, 振込など)
  bankName            String? @map("bank_name") @db.VarChar(50) // 銀行
  bankBranchCode      String? @map("bank_branch_code") @db.VarChar(20) // 支店番号
  bankAccountType     String? @map("bank_account_type") @db.VarChar(20) // 口座種類 (普通など)
  bankAccountNumber   String? @map("bank_account_number") @db.VarChar(20) // 口座番号
  bankAccountName     String? @map("bank_account_name") @db.VarChar(100) // 名義
  bankAccountNameKana String? @map("bank_account_name_kana") @db.VarChar(100) // 名義（半角カナ）
  bankCardImageUrl    String? @map("bank_card_image_url") @db.Text // キャッシュカード画像URL
  transferNumber      String? @map("transfer_number") @db.VarChar(50) // 振込番号

  // 貸与品・稼働形態
  equipmentBattery     String? @map("equipment_battery") @db.VarChar(50) // バッテリー
  equipmentBag         String? @map("equipment_bag") @db.VarChar(50) // カバン
  equipmentMobile      String? @map("equipment_mobile") @db.VarChar(50) // 携帯
  flyerDeliveryMethod  String? @map("flyer_delivery_method") @db.VarChar(50) // チラシ届け
  transportationMethod String? @map("transportation_method") @db.VarChar(50) // 移動方法 (徒歩など)

  // 給与・評価レート情報
  ratePlan          String? @map("rate_plan") @db.VarChar(50) // Rate (Basic, Regular, Advancedなど)
  rate1Type         Float?  @map("rate_1_type") // 1type
  rate2Type         Float?  @map("rate_2_type") // 2type
  rate3Type         Float?  @map("rate_3_type") // 3type
  rate4Type         Float?  @map("rate_4_type") // 4type
  rate5Type         Float?  @map("rate_5_type") // 5type
  rate6Type         Float?  @map("rate_6_type") // 6type
  transportationFee String? @map("transportation_fee") @db.VarChar(50) // Transporation fee (FULL, 1000など)
  trainingAllowance String? @map("training_allowance") @db.VarChar(50) // 研修手当

  // 目標・実績（KPI）
  rank            String? @db.VarChar(10) // ランク (A, Cなど)
  attendanceCount Int?    @default(0) @map("attendance_count") // 出勤回数
  minTypes        Int?    @map("min_types") // 最低種類
  maxTypes        Int?    @map("max_types") // 最高種類
  minSheets       Int?    @map("min_sheets") // 最低枚数1
  maxSheets       Int?    @map("max_sheets") // 最高枚数1
  targetAmount    String? @map("target_amount") @db.VarChar(50) // 目標金額 (¥8,000–¥9,999など)
  rateMode        String  @default("manual") @map("rate_mode") @db.VarChar(10) // 'auto' | 'manual'

  // プロフィール写真
  avatarUrl String? @map("avatar_url") @db.Text

  // システム用
  note      String?  @db.Text // 備考
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 評価スコア
  currentScore   Int      @default(100) @map("current_score") // 最新の総合スコア

  schedules      DistributionSchedule[]
  shifts         DistributorShift[]
  expenses       DistributorExpense[]
  payrollRecords DistributorPayrollRecord[]
  tasks          Task[]
  taskTemplates  TaskTemplate[]
  complaints            Complaint[]
  appDistributionLogs   AppDistributionLog[]
  distributionSessions  DistributionSession[]
  adminNotifications    AdminNotification[]
  evaluations           DistributorEvaluation[]
  fieldInspections      FieldInspection[]

  @@index([branchId])
  @@index([visaExpiryDate])
  @@map("flyer_distributors")
}

model DistributorShift {
  id            Int              @id @default(autoincrement())
  distributorId Int              @map("distributor_id")
  distributor   FlyerDistributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  date          DateTime         @db.Date
  status        String           @default("REQUESTED") @db.VarChar(20)
  // REQUESTED / APPROVED / REJECTED / CANCELED
  note          String?          @db.Text
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@unique([distributorId, date])
  @@map("distributor_shifts")
}

model DistributorExpense {
  id            Int              @id @default(autoincrement())
  distributorId Int              @map("distributor_id")
  distributor   FlyerDistributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  date          DateTime         @db.Date
  amount        Int
  description   String           @db.Text
  status        String           @default("PENDING") @db.VarChar(20)
  // PENDING / APPROVED / REJECTED
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@map("distributor_expenses")
}

// --- 在留資格マスタ ---
model VisaType {
  id                  Int      @id @default(autoincrement())
  name                String   @unique @db.VarChar(100)
  nameEn              String   @default("") @map("name_en") @db.VarChar(100)
  sortOrder           Int      @default(100) @map("sort_order")
  canContract         Boolean  @default(false) @map("can_contract")         // 業務委託可否
  canPartTime         Boolean  @default(false) @map("can_part_time")         // アルバイト・パート可否
  workHourLimit       Int?     @map("work_hour_limit")                       // 就労制限時間(null=なし, 28=週28h)
  requiresDesignation Boolean  @default(false) @map("requires_designation") // 指定書要確認
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  distributors FlyerDistributor[]
  applicants   Applicant[]
  employees    Employee[]

  @@map("visa_types")
}

// --- 支店マスタ (Branches) ---
model Branch {
  id Int @id @default(autoincrement())

  // 支店名
  nameJa String @map("name_ja") @db.VarChar(100) // 日本語名 (例: 高田馬場)
  nameEn String @map("name_en") @db.VarChar(100) // 英語名 (例: Takadanobaba)

  // 店舗情報
  prefix       String? @db.VarChar(10) // スタッフIDプレフィックス (例: "MBF")
  staffIdSeq   Int     @default(0) @map("staff_id_seq") // スタッフID連番カウンター（次の番号 = staffIdSeq + 1）
  postalCode   String? @map("postal_code") @db.VarChar(10) // 郵便番号
  address      String? @db.Text // 住所（日本語）
  addressEn    String? @map("address_en") @db.Text // 住所（英語）
  googleMapUrl String? @map("google_map_url") @db.Text // GoogleMapリンク
  openDate     DateTime? @map("open_date") @db.Date // 開店日
  openingTime  String? @map("opening_time") @db.VarChar(10) // 開店時間 (例: "07:00")
  closingTime  String? @map("closing_time") @db.VarChar(10) // 閉店時間 (例: "22:00")
  closedDays   String? @map("closed_days") @db.VarChar(50) // 定休日 (例: "火曜日", "土日祝")

  // 定休日の代替出勤先支店
  alternateBranchId Int?    @map("alternate_branch_id")
  alternateBranch   Branch? @relation("AlternateBranch", fields: [alternateBranchId], references: [id])
  alternateFor      Branch[] @relation("AlternateBranch") // 逆参照

  // 店長枠 (1〜4) : Employeeとの紐付け
  manager1Id Int? @map("manager1_id")
  manager2Id Int? @map("manager2_id")
  manager3Id Int? @map("manager3_id")
  manager4Id Int? @map("manager4_id")

  manager1 Employee? @relation("BranchManager1", fields: [manager1Id], references: [id])
  manager2 Employee? @relation("BranchManager2", fields: [manager2Id], references: [id])
  manager3 Employee? @relation("BranchManager3", fields: [manager3Id], references: [id])
  manager4 Employee? @relation("BranchManager4", fields: [manager4Id], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション（この支店に所属する配布員）
  distributors   FlyerDistributor[]
  schedules      DistributionSchedule[]
  employees      Employee[] @relation("BranchEmployees")
  tasksByBranch  Task[]     @relation("TaskBranch")
  taskAssignees  TaskAssignee[] @relation("TaskAssigneeBranch")
  taskTemplates  TaskTemplate[] @relation("TaskTemplateBranch")
  complaints     Complaint[]

  @@map("branches")
}

// ==========================================
// トランザクション (配布予定・実績)
// ==========================================

// --- 1. 配布スケジュール (誰が、どこで、いつ) ---
model DistributionSchedule {
  id          Int            @id @default(autoincrement())
  jobNumber   String?        @map("job_number") @db.VarChar(50) // 仕事番号
  jobCategory String?        @map("job_category") @db.VarChar(50) // 仕事分類
  status      ScheduleStatus @default(UNSTARTED)
  date        DateTime?      @db.Date // 年月日

  // Who (誰が) - 配布員マスタ
  distributorId Int?              @map("distributor_id")
  distributor   FlyerDistributor? @relation(fields: [distributorId], references: [id])

  // 拠点 - 支店マスタ
  branchId Int?    @map("branch_id")
  branch   Branch? @relation(fields: [branchId], references: [id])

  // Where (どこで) - City / Areaマスタと紐付け
  cityId Int?  @map("city_id")
  city   City? @relation(fields: [cityId], references: [id])

  areaId Int?  @map("area_id")
  area   Area? @relation(fields: [areaId], references: [id])

  // 単価・備考
  areaUnitPrice Float?  @map("area_unit_price") // エリア単価
  sizeUnitPrice Float?  @map("size_unit_price") // サイズ単価
  remarks       String? @db.Text // 備考

  // コンプライアンスチェック
  checkFlyerPhoto   Boolean   @default(false) @map("check_flyer_photo")
  checkAppOperation Boolean   @default(false) @map("check_app_operation")
  checkGps          Boolean   @default(false) @map("check_gps")
  checkMapPhoto     Boolean   @default(false) @map("check_map_photo")
  checkedById       Int?      @map("checked_by_id")
  checkedAt         DateTime? @map("checked_at")
  checkedBy         Employee? @relation("ComplianceChecker", fields: [checkedById], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // リレーション (What: このスケジュールで配る最大6種類のチラシ)
  items              DistributionItem[]
  tasks              Task[]
  taskTemplates      TaskTemplate[]
  complaints         Complaint[]
  session            DistributionSession?
  adminNotifications AdminNotification[]
  relayTasks         RelayTask[]
  pickingVerification PickingVerification?

  @@index([distributorId, date])
  @@index([branchId, date])
  @@index([status])
  @@map("distribution_schedules")
}

// --- 2. 配布アイテム明細 (何を、何枚) ---
// --- 2. 配布アイテム明細 (何を、何枚) ---
model DistributionItem {
  id Int @id @default(autoincrement())

  // 親スケジュールとの紐付け
  scheduleId Int                  @map("schedule_id")
  schedule   DistributionSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  // 何番目のチラシか (1〜6)
  slotIndex Int @map("slot_index")

  // What (何を)
  flyerName String? @map("flyer_name") @db.VarChar(200) // チラシ名
  flyerCode String? @map("flyer_code") @db.VarChar(50) // チラシコード

  // 顧客マスタとの紐付け
  customerId Int?      @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id])

  // 受注テーブル(Order)のIDが入る枠
  orderId Int? @map("order_id")

  // 日付フォーマット
  startDate DateTime? @map("start_date") @db.Date // 配布開始日
  endDate   DateTime? @map("end_date") @db.Date // 配布期限
  spareDate DateTime? @map("spare_date") @db.Date // 配布期限予備

  method       String? @db.VarChar(50) // 配布方法 (例: 軒並)
  plannedCount Int?    @map("planned_count") // 予定枚数
  actualCount  Int?    @map("actual_count") // 配布枚数

  // ★ 追加: アイテムごとの備考
  remarks String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ★ 以下を追加 (Flyerとの紐付け)
  flyerId Int? @map("flyer_id")
  flyer   Flyer? @relation(fields: [flyerId], references: [id])

  billingUnitPrice Float? @map("billing_unit_price")

  @@index([scheduleId])
  @@index([customerId])
  @@map("distribution_items")
}

enum ScheduleStatus {
  UNSTARTED     // 未開始
  IN_PROGRESS   // 進行中（管理者手動）
  DISTRIBUTING  // 配布中（配布員がSTARTを押した、GPS追跡中）
  COMPLETED     // 完了
}

// --- 中継/回収 ---
enum RelayType {
  RELAY      // 中継（チラシを届ける）
  COLLECTION // 回収（チラシを回収する）
  FULL_RELAY // 全中継（全チラシを届ける）
}

enum RelayStatus {
  PENDING     // 要中継 / 要回収
  IN_PROGRESS // 中継中 / 回収中
  COMPLETED   // 完了
  CANCELLED   // キャンセル
}

model RelayTask {
  id          Int          @id @default(autoincrement())
  scheduleId  Int          @map("schedule_id")
  schedule    DistributionSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  type        RelayType    // RELAY or COLLECTION
  status      RelayStatus  @default(PENDING)

  // ドライバー/回収者 - 社員選択 or フリーテキスト
  driverId    Int?         @map("driver_id")
  driver      Employee?    @relation("RelayDriver", fields: [driverId], references: [id])
  driverName  String?      @map("driver_name") @db.VarChar(100) // 業務委託等のフリーテキスト

  // 場所
  locationName String?     @map("location_name") @db.VarChar(200)
  latitude     Float?
  longitude    Float?

  // 到着時間枠
  timeSlotStart String?    @map("time_slot_start") @db.VarChar(5) // "09:00"
  timeSlotEnd   String?    @map("time_slot_end") @db.VarChar(5)   // "10:00"

  // タスク実施日（スケジュールの日付と異なる場合に使用、繰越時に翌日にセット）
  date         DateTime?    @db.Date

  // 優先順位（ドラッグ&ドロップ並べ替え用）
  sortOrder   Int          @default(0) @map("sort_order")

  // メモ
  note        String?      @db.Text

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([scheduleId])
  @@index([status])
  @@index([driverId])
  @@index([type, status])
  @@index([date])
  @@map("relay_tasks")
}

// --- 配布セッション未完了理由 ---
enum IncompleteReason {
  AREA_DONE  // エリア終了（全戸配布済み）
  GIVE_UP    // ギブアップ
  OTHER      // その他
}

// --- 管理者通知種別 ---
enum AdminNotificationType {
  DISTRIBUTION_START    // 配布開始
  DISTRIBUTION_FINISH   // 配布完了
  ALERT                 // アラート通知
}

// --- アラート定義の周期 ---
enum AlertFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// --- アラート定義の対象タイプ ---
enum AlertTargetType {
  ALL          // 全管理者
  ROLE         // 特定役職
  DEPARTMENT   // 特定部署
  EMPLOYEE     // 特定社員
}

// ==========================================
// チラシ・在庫管理モジュール
// ==========================================

// --- 業種マスタ ---
model Industry {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  flyers    Flyer[]
  customers Customer[]
  @@map("industries")
}

// --- 配布方法マスター ---
model DistributionMethod {
  id           Int      @id @default(autoincrement())
  name         String   @unique @db.VarChar(100)
  // 'all' = 軒並み (door_to_door_count)
  // 'detached' = 戸建限定 (door_to_door_count - multi_family_count)
  // 'apartment' = 集合住宅限定 (multi_family_count)
  capacityType String   @default("all") @map("capacity_type") @db.VarChar(20)
  priceAddon   Float    @default(0.0) @map("price_addon")
  sortOrder    Int      @default(100) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("distribution_methods")
}

// --- 折り加工マスター ---
model FoldingType {
  id        Int     @id @default(autoincrement())
  name      String  @unique @db.VarChar(50)
  unitPrice Float   @default(0.0) @map("unit_price")
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@map("folding_types")
}

// --- 配布期間別単価加算マスター ---
model DistributionPeriodPrice {
  id           Int     @id @default(autoincrement())
  minDays      Int     @map("min_days")
  maxDays      Int?    @map("max_days")
  priceAddon   Float   @default(0.0) @map("price_addon") // 単価への加算額 (例: 0.5 → +0.5円)
  label        String? @db.VarChar(50)

  @@map("distribution_period_prices")
}

// --- サイズマスタ ---
model FlyerSize {
  id               Int      @id @default(autoincrement())
  name             String   @unique @db.VarChar(20) // 例: A4, B4, A3
  basePriceAddon   Float    @default(0) @map("base_price_addon")
  printUnitPrice   Float    @default(5.0) @map("print_unit_price")
  isFoldRequired   Boolean  @default(false) @map("is_fold_required")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  flyers             Flyer[]
  partnerAreaPrices  PartnerAreaPrice[]
  @@map("flyer_sizes")
}

// --- 折りステータス (Enum) ---
enum FoldStatus {
  NEEDS_FOLDING       // 要折 (自社で折る作業が必要。この状態では配布不可)
  NO_FOLDING_REQUIRED // 折無し (折らずにそのまま配布。配布可能)
  FOLDED              // 折済 (納品時から折られている、または自社で折り作業完了。配布可能)
}

// --- チラシ案件マスタ (Flyer) ---
model Flyer {
  id           Int        @id @default(autoincrement())
  name         String     @db.VarChar(200)
  flyerCode    String?    @unique @map("flyer_code") @db.VarChar(50)
  bundleCount  Int?       @map("bundle_count") // 1束あたりの枚数

  // 関連マスタ
  customerId   Int        @map("customer_id")
  customer     Customer   @relation(fields: [customerId], references: [id])
  industryId   Int        @map("industry_id")
  industry     Industry   @relation(fields: [industryId], references: [id])
  sizeId       Int        @map("size_id")
  size         FlyerSize  @relation(fields: [sizeId], references: [id])

  startDate    DateTime?  @map("start_date") @db.Date
  endDate      DateTime?  @map("end_date") @db.Date

  // ★ いただいた3つのステータスを適用
  foldStatus   FoldStatus @default(NO_FOLDING_REQUIRED) @map("fold_status")

  totalReceived Int       @default(0) @map("total_received") // 累計納品枚数
  stockCount    Int       @default(0) @map("stock_count")    // 現在の有効在庫枚数

  remarks      String?    @db.Text
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  transactions FlyerTransaction[]
  // DistributionItem(スケジュール明細)との紐付けも後ほど追加します
  distributionItems DistributionItem[]
  orderDistributions OrderDistribution[]
  orderPrintings     OrderPrinting[]
  qrCodes QrCode[]

  @@index([customerId])
  @@map("flyers")
}

// --- 入出庫種類 (Enum) ---
enum TransactionType {
  RECEIVE   @map("納品(入庫)")
  PICKUP    @map("引取(出庫)")
  TRANSFER  @map("移動")
  DISPOSE   @map("廃棄・調整")
}

// --- 入出庫ステータス (Enum) ---
enum TransactionStatus {
  PENDING   @map("予定")
  COMPLETED @map("完了")
  CANCELED  @map("キャンセル")
}

// --- 入出庫履歴テーブル (FlyerTransaction) ---
model FlyerTransaction {
  id              Int               @id @default(autoincrement())
  flyerId         Int               @map("flyer_id")
  flyer           Flyer             @relation(fields: [flyerId], references: [id], onDelete: Cascade)

  transactionType TransactionType   @map("transaction_type")
  
  expectedAt      DateTime          @map("expected_at") @db.DateTime(0)
  actualAt        DateTime?         @map("actual_at") @db.DateTime(0)
  
  count           Int               // 常に絶対値で入れ、種類に応じてプラスマイナスを計算する

  status          TransactionStatus @default(PENDING)
  isDelayed       Boolean           @default(false) @map("is_delayed") 

  // 担当者 (ドライバーや検品者)
  employeeId      Int?              @map("employee_id")
  employee        Employee?         @relation(fields: [employeeId], references: [id])

  note            String?           @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@map("flyer_transactions")
}

// ==========================================
// パートナー（外注先）マスタ
// ==========================================
model Partner {
  id            Int         @id @default(autoincrement())
  name          String      @db.VarChar(100) // 外注先企業名
  contactInfo   String?     @map("contact_info") @db.Text

  // ★ 文字列から「パートナータイプマスタ」への紐付けに変更
  partnerTypeId Int         @map("partner_type_id")
  partnerType   PartnerType @relation(fields: [partnerTypeId], references: [id])

  // ★ Phase1 拡張フィールド
  hasGpsTracking  Boolean   @default(false) @map("has_gps_tracking")
  contactPerson   String?   @map("contact_person") @db.VarChar(100)
  phone           String?   @db.VarChar(20)
  email           String?   @db.VarChar(100)
  address         String?   @db.VarChar(500)
  isActive        Boolean   @default(true) @map("is_active")
  note            String?   @db.Text

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  printings         OrderPrinting[]
  newspaperInserts  OrderNewspaperInsert[]
  designs           OrderDesign[]
  complaints        Complaint[]
  orders            Order[]
  flyerPrices       PartnerFlyerPrice[]

  // ★ Phase1 新リレーション
  coverageAreas     PartnerCoverageArea[]
  areaPrices        PartnerAreaPrice[]
  incidents         PartnerIncident[]

  @@map("partners")
}

model PartnerFlyerPrice {
  id            Int      @id @default(autoincrement())
  partnerId     Int      @map("partner_id")
  partner       Partner  @relation(fields: [partnerId], references: [id])
  flyerName     String   @map("flyer_name") @db.VarChar(200)
  customerCode  String?  @map("customer_code") @db.VarChar(50)
  flyerCode     String?  @map("flyer_code") @db.VarChar(50)
  unitPrice     Float    @map("unit_price")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([partnerId, flyerName, customerCode, flyerCode])
  @@index([partnerId])
  @@map("partner_flyer_prices")
}

// --- パートナータイプマスタ (追加) ---
model PartnerType {
  id        Int       @id @default(autoincrement())
  name      String    @unique @db.VarChar(50) // 例: "印刷会社", "新聞折込" など
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  partners  Partner[]

  @@map("partner_types")
}

// --- パートナー対応エリア（パートナー×エリア紐付け） ---
model PartnerCoverageArea {
  id        Int      @id @default(autoincrement())
  partnerId Int      @map("partner_id")
  areaId    Int      @map("area_id")
  createdAt DateTime @default(now()) @map("created_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  area    Area    @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@unique([partnerId, areaId])
  @@index([partnerId])
  @@index([areaId])
  @@map("partner_coverage_areas")
}

// --- パートナー配布単価マスタ ---
model PartnerAreaPrice {
  id             Int      @id @default(autoincrement())
  partnerId      Int      @map("partner_id")
  prefectureId   Int      @map("prefecture_id")
  cityId         Int?     @map("city_id")
  flyerSizeId    Int      @map("flyer_size_id")
  periodDaysMin  Int      @map("period_days_min")
  periodDaysMax  Int      @map("period_days_max")
  unitPrice      Float    @map("unit_price")
  note           String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  partner    Partner    @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  prefecture Prefecture @relation(fields: [prefectureId], references: [id])
  city       City?      @relation(fields: [cityId], references: [id])
  flyerSize  FlyerSize  @relation(fields: [flyerSizeId], references: [id])

  @@index([partnerId])
  @@map("partner_area_prices")
}

// --- パートナーインシデント管理 ---
enum PartnerIncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PartnerIncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model PartnerIncident {
  id          Int                      @id @default(autoincrement())
  partnerId   Int                      @map("partner_id")
  title       String                   @db.VarChar(200)
  description String                   @db.Text
  severity    PartnerIncidentSeverity  @default(MEDIUM)
  status      PartnerIncidentStatus    @default(OPEN)
  occurredAt  DateTime                 @map("occurred_at") @db.Date
  resolvedAt  DateTime?                @map("resolved_at")
  resolvedBy  Int?                     @map("resolved_by")
  note        String?                  @db.Text
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  partner  Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  resolver Employee? @relation("PartnerIncidentResolver", fields: [resolvedBy], references: [id])

  @@index([partnerId])
  @@index([status])
  @@map("partner_incidents")
}

// ==========================================
// 受注管理モジュール
// ==========================================

// --- 受注全体ステータス ---
enum OrderStatus {
  DRAFT             @map("一時保存")
  PLANNING          @map("提案中")
  PENDING_PAYMENT   @map("入金待ち")
  PENDING_SUBMISSION @map("入稿待ち")
  PENDING_REVIEW    @map("審査待ち")
  ADJUSTING         @map("調整中")
  CONFIRMED         @map("受注確定")
  IN_PROGRESS       @map("作業中")
  COMPLETED         @map("完了")
  CANCELED          @map("キャンセル")
}

// --- 追加: 承認・審査ステータス ---
enum ApprovalStatus {
  APPROVED    @map("承認済")
  REJECTED    @map("不承認")
}

// --- 審査履歴テーブル ---
model OrderApproval {
  id          Int            @id @default(autoincrement())
  orderId     Int            @map("order_id")
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  approverId  Int?           @map("approver_id")
  approver    Employee?      @relation(fields: [approverId], references: [id])
  
  status      ApprovalStatus
  comment     String?        @db.Text
  createdAt   DateTime       @default(now()) @map("created_at")

  @@map("order_approvals")
}

// ★ 追加: 受注経路
enum OrderSource {
  WEB_EC
  SALES_INTERNAL
  PARTNER_IMPORT
}

// --- 受注ヘッダ (親) ---
model Order {
  id           Int         @id @default(autoincrement())
  orderNo      String      @unique @map("order_no") @db.VarChar(50) 
  
  title        String?     @db.VarChar(200)
  orderSource  OrderSource @default(WEB_EC) @map("order_source")
  paymentMethod String?    @map("payment_method") @db.VarChar(50) 
  
  customerId   Int?        @map("customer_id")
  customer     Customer?   @relation(fields: [customerId], references: [id])

  partnerId    Int?        @map("partner_id")
  partner      Partner?    @relation(fields: [partnerId], references: [id])

  salesRepId   Int?        @map("sales_rep_id")
  salesRep     Employee?   @relation(fields: [salesRepId], references: [id])

  orderDate    DateTime    @map("order_date") @db.Date 
  totalAmount  Int?        @map("total_amount") 
  status       OrderStatus @default(DRAFT)
  remarks      String?     @db.Text

  contacts           OrderContact[]
  distributions      OrderDistribution[]
  printings          OrderPrinting[]
  newspaperInserts   OrderNewspaperInsert[]
  designs            OrderDesign[]
  payments           Payment[]
  approvals          OrderApproval[]
  notifications      Notification[]
  documents          Document[]
  billingItem        BillingStatementItem?

  @@index([customerId])
  @@index([partnerId])
  @@index([status, orderDate])
  @@index([salesRepId])
  @@map("orders")
}



// --- 受注と顧客担当者の中間テーブル (1受注 : N担当者) ---
model OrderContact {
  id                Int             @id @default(autoincrement())
  orderId           Int             @map("order_id")
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  customerContactId Int             @map("customer_contact_id")
  customerContact   CustomerContact @relation(fields: [customerContactId], references: [id])

  @@map("order_contacts")
}

// --- 1. 配布依頼 ---
model OrderDistribution {
  id           Int       @id @default(autoincrement())
  orderId      Int       @map("order_id")
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // ★ どのチラシを配るか
  flyerId      Int       @map("flyer_id")
  flyer        Flyer     @relation(fields: [flyerId], references: [id])

  method       String    @db.VarChar(50) // 軒並み, 戸建限定 など
  plannedCount Int       @map("planned_count") // 配布予定枚数

  // ★ 1枚あたりの配布単価 (管理者が手動設定)
  distributionUnitPrice Float? @map("distribution_unit_price")

  startDate    DateTime? @map("start_date") @db.Date // 配布開始日
  endDate      DateTime? @map("end_date") @db.Date   // 配布完了期限
  spareDate    DateTime? @map("spare_date") @db.Date // ★ 予備期限 (悪天候時の許容日)

  status       String    @default("UNSTARTED") @db.VarChar(20) // 未手配, 手配済, 配布中, 完了
  remarks      String?   @db.Text

  // ★ 配布エリア (1:N)
  areas        OrderDistributionArea[]

  @@map("order_distributions")
}

// --- 配布依頼とエリアの中間テーブル (1配布依頼 : Nエリア) ---
model OrderDistributionArea {
  id                  Int               @id @default(autoincrement())
  orderDistributionId Int               @map("order_distribution_id")
  orderDistribution   OrderDistribution @relation(fields: [orderDistributionId], references: [id], onDelete: Cascade)
  
  areaId              Int               @map("area_id")
  area                Area              @relation(fields: [areaId], references: [id])

  @@map("order_distribution_areas")
}

model OrderPrinting {
  id                   Int       @id @default(autoincrement())
  orderId              Int       @map("order_id")
  order                Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  flyerId              Int?      @map("flyer_id")
  flyer                Flyer?    @relation(fields: [flyerId], references: [id])

  partnerId            Int?      @map("partner_id")
  partner              Partner?  @relation(fields: [partnerId], references: [id]) // 印刷発注先

  printCount           Int       @map("print_count") // 印刷枚数
  // ★ 1枚あたりの印刷単価 (管理者が手動設定)
  printingUnitPrice    Float?    @map("printing_unit_price")
  paperSizeId          Int?      @map("paper_size_id")
  
  paperType            String?   @map("paper_type") @db.VarChar(50) // コート, マット等
  paperWeight          String?   @map("paper_weight") @db.VarChar(20) // 73kg, 90kg等
  colorType            String?   @map("color_type") @db.VarChar(20) // 両面カラー等
  
  // ==========================================
  // ★ ここから追加：入稿・印刷オプション
  foldingOption        String?   @map("folding_option") @db.VarChar(100) // 3つ折り、二つ折り等
  foldingTypeId        Int?      @map("folding_type_id") // FoldingTypeマスタのID
  foldingUnitPrice     Float?    @map("folding_unit_price") // チェックアウト時の折り加工単価スナップショット
  sampleRequired       Boolean   @default(false) @map("sample_required") // サンプルが必要か
  sampleShippingAddress String?  @map("sample_shipping_address") @db.Text // サンプル配送先
  remarks              String?   @db.Text // その他備考・指示
  // ==========================================

  designFileUrl        String?   @map("design_file_url") @db.Text // 原稿データのURL

  // ★ 今回追加: 表面と裏面のプレビュー用URL
  frontDesignUrl       String?   @map("front_design_url") @db.Text
  backDesignUrl        String?   @map("back_design_url") @db.Text

  orderDate            DateTime? @map("order_date") @db.Date // 印刷発注日
  expectedDeliveryDate DateTime? @map("expected_delivery_date") @db.Date // 納品予定日
  
  status               String    @default("UNORDERED") @db.VarChar(20) // 未発注, 発注済, 納品済

  @@map("order_printings")
}

// --- 3. 新聞折込依頼 ---
model OrderNewspaperInsert {
  id                Int       @id @default(autoincrement())
  orderId           Int       @map("order_id")
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  partnerId         Int?      @map("partner_id")
  partner           Partner?  @relation(fields: [partnerId], references: [id]) // 折込手配会社

  insertDate        DateTime? @map("insert_date") @db.Date // 折込指定日
  plannedCount      Int       @map("planned_count") // 折込枚数
  newspaperName     String?   @map("newspaper_name") @db.VarChar(50) // 指定紙 (読売, 朝日等)
  areaSpecification String?   @map("area_specification") @db.Text // エリア指定メモ

  status            String    @default("UNORDERED") @db.VarChar(20) // 未手配, 手配済, 完了

  @@map("order_newspaper_inserts")
}

// --- 4. デザイン依頼 ---
model OrderDesign {
  id                 Int       @id @default(autoincrement())
  orderId            Int       @map("order_id")
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  partnerId          Int?      @map("partner_id")
  partner            Partner?  @relation(fields: [partnerId], references: [id]) // 外注デザイナーの場合
  
  employeeId         Int?      @map("employee_id")
  employee           Employee? @relation(fields: [employeeId], references: [id]) // 社内デザイナーの場合

  designConcept      String?   @map("design_concept") @db.Text
  firstDraftDeadline DateTime? @map("first_draft_deadline") @db.Date
  finalDeadline      DateTime? @map("final_deadline") @db.Date
  
  finalDataUrl       String?   @map("final_data_url") @db.Text // 完成デザインデータURL

  status             String    @default("NOT_STARTED") @db.VarChar(20) // 未着手, 制作中, 校了

  @@map("order_designs")
}

// ==========================================
// ★ 追加: 反響測定（QRコード・トラッキング）モジュール
// ==========================================

model QrCode {
  id          Int      @id @default(autoincrement())

  flyerId     Int?     @map("flyer_id")
  flyer       Flyer?   @relation(fields: [flyerId], references: [id])

  // スタンドアロンQR用: チラシと紐付かない場合の直接オーナー
  customerId  Int?     @map("customer_id")
  customer    Customer? @relation(fields: [customerId], references: [id])

  alias       String   @unique @db.VarChar(100)
  redirectUrl String   @map("redirect_url") @db.Text
  memo        String?  @db.VarChar(255)

  isActive    Boolean  @default(true) @map("is_active")

  // ★ 追加: メール通知設定
  notifyOnScan       Boolean  @default(false) @map("notify_on_scan")
  notificationEmails String?  @map("notification_emails") @db.Text // カンマ区切りで複数保存

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  scanLogs    QrScanLog[]

  @@map("qr_codes")
}

model QrScanLog {
  id          Int      @id @default(autoincrement())
  
  qrCodeId    Int      @map("qr_code_id")
  qrCode      QrCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)

  scannedAt   DateTime @default(now()) @map("scanned_at") 

  ipAddress   String?  @map("ip_address") @db.VarChar(50)
  userAgent   String?  @map("user_agent") @db.Text
  deviceType  String?  @map("device_type") @db.VarChar(50)
  os          String?  @db.VarChar(50)
  browser     String?  @db.VarChar(50)
  location    String?  @db.VarChar(100) 
  
  // ★ 追加: ユニークユーザー識別用ID (Cookieの値を保存)
  visitorId   String?  @map("visitor_id") @db.VarChar(100)

  @@map("qr_scan_logs")
}

// --- 決済方法 ---
enum PaymentMethod {
  CREDIT_CARD     @map("クレジットカード")
  INVOICE         @map("請求書払い")
  BANK_TRANSFER   @map("銀行振込")
}

// --- 決済ステータス ---
enum PaymentStatus {
  PENDING     @map("未決済")
  AUTHORIZED  @map("与信枠確保")
  COMPLETED   @map("入金済")
  FAILED      @map("決済失敗")
  REFUNDED    @map("返金済")
}

// --- 決済履歴テーブル ---
model Payment {
  id              Int           @id @default(autoincrement())
  
  orderId         Int           @map("order_id")
  order           Order         @relation(fields: [orderId], references: [id])
  
  amount          Int           
  method          PaymentMethod 
  status          PaymentStatus @default(PENDING) 
  
  transactionId   String?       @map("transaction_id") @db.VarChar(100) 
  paidAt          DateTime?     @map("paid_at") @db.DateTime(0) 
  
  note            String?       @db.Text 
  
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

// ==========================================
// 勤怠・経費関連 Enum
// ==========================================

enum AttendanceStatus {
  PENDING   @map("承認待ち")
  APPROVED  @map("承認済")
  REJECTED  @map("却下")
}

enum ExpenseType {
  TRANSPORTATION @map("交通費")
  OTHER          @map("その他経費")
}

enum ExpenseStatus {
  PENDING   @map("承認待ち")
  APPROVED  @map("承認済")
  REJECTED  @map("却下")
}

// ==========================================
// 勤怠管理テーブル
// ==========================================

model AttendanceType {
  id              Int      @id @default(autoincrement())
  code            String   @unique @db.VarChar(50) // プログラム判定用 (例: 'WORK', 'HOLIDAY_WORK', 'PAID_LEAVE')
  name            String   @db.VarChar(50)         // 画面表示用 (例: '通常出勤', '休日出勤', '有給休暇')
  
  // ★ 追加: 給与の割増倍率 (通常は 1.0、休日出勤なら 1.25 や 1.35)
  wageMultiplier  Float    @default(1.0) @map("wage_multiplier")
  
  // 制御フラグ
  isWorking       Boolean  @default(false) @map("is_working")   // 出勤扱いか（時間を入力させるか）
  isPaid          Boolean  @default(false) @map("is_paid")      // 有給扱いか（みなし給与を発生させるか）
  isDeducting     Boolean  @default(false) @map("is_deducting") // 有給残日数を減らす対象か
  
  isActive        Boolean  @default(true) @map("is_active")

  attendances     Attendance[]

  @@map("attendance_types")
}

model Attendance {
  id             Int              @id @default(autoincrement())
  
  employeeId     Int              @map("employee_id")
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  date           DateTime         @db.Date // 勤務日

  // ★ 変更: EnumをやめてマスタテーブルのIDを保存する
  attendanceTypeId Int              @map("attendance_type_id")
  attendanceType   AttendanceType   @relation(fields: [attendanceTypeId], references: [id])
  
  startTime      String?          @map("start_time") @db.VarChar(5)
  endTime        String?          @map("end_time") @db.VarChar(5)
  breakMinutes   Int?             @default(60) @map("break_minutes")
  
  workHours      Float            @map("work_hours") // 実労働時間（時間単位, 例: 8.0）
  calculatedWage Int?             @map("calculated_wage") // この日の給与（時給 * 実労働時間）

  // ★ 以下の4行を追加 (承認した人と日時、却下理由を記録する枠)
  approverId     Int?             @map("approver_id")
  approver       Employee?        @relation("AttendanceApprover", fields: [approverId], references: [id])
  approvedAt     DateTime?        @map("approved_at")
  rejectionReason String?         @map("rejection_reason") @db.Text
  
  note           String?          @db.Text
  status         AttendanceStatus @default(PENDING)

  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@unique([employeeId, date]) // ★ 同じ日に2重で打刻できないようにする制約
  @@map("attendances")
}

// ==========================================
// 経費精算テーブル
// ==========================================
model Expense {
  id             Int           @id @default(autoincrement())
  
  employeeId     Int           @map("employee_id")
  employee       Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  date           DateTime      @db.Date // 発生日
  type           ExpenseType   // 交通費 or その他
  amount         Int           // 金額
  description    String        @db.Text // 経路や目的（例: 新宿〜東京 往復など）
  receiptUrl     String?       @map("receipt_url") @db.Text // 領収書の画像URL（任意）
  
  status         ExpenseStatus @default(PENDING)
  
  // ★ 承認者に関する情報
  approverId     Int?          @map("approver_id")
  approver       Employee?     @relation("ExpenseApprover", fields: [approverId], references: [id])
  approvedAt     DateTime?     @map("approved_at")
  rejectionReason String?      @map("rejection_reason") @db.Text // 却下時の理由
  
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@map("expenses")
}

// --- 有給休暇のトランザクション種別 ---
enum LeaveTransactionType {
  GRANTED  @map("付与")
  USED     @map("消化")
  EXPIRED  @map("期限切れ消滅")
  ADJUSTED @map("手動調整") // 管理者による直接修正用
}

// --- 有給休暇台帳テーブル ---
model PaidLeaveLedger {
  id          Int                  @id @default(autoincrement())
  
  employeeId  Int                  @map("employee_id")
  employee    Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  date        DateTime             @db.Date // 発生日（付与された日、休んだ日など）
  type        LeaveTransactionType // 付与 or 消化 or 消滅
  
  days        Float                // 日数 (半休があるため Float。付与ならプラス、消化ならマイナスの値を入れる)
  
  validUntil  DateTime?            @db.Date // ★ 付与(GRANTED)の場合のみ、この有給の「有効期限（通常2年後）」をセット
  
  note        String?              @db.Text // 「入社半年付与」「10/12 体調不良による有給」などのメモ

  createdAt   DateTime             @default(now()) @map("created_at")

  @@map("paid_leave_ledgers")
}

// --- 給与計算ステータス ---
enum PayrollStatus {
  DRAFT      @map("下書き")
  CONFIRMED  @map("確定済")
  PAID       @map("支払済")
}

// --- 給与明細テーブル ---
model PayrollRecord {
  id                   Int            @id @default(autoincrement())
  employeeId           Int            @map("employee_id")
  employee             Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employmentType       EmploymentType @map("employment_type")
  periodStart          DateTime       @map("period_start") @db.Date
  periodEnd            DateTime       @map("period_end") @db.Date
  paymentCycle         PaymentCycle   @map("payment_cycle")
  // 正社員用
  baseSalary           Int            @default(0) @map("base_salary")
  allowance            Int            @default(0)
  workingDaysInPeriod  Int            @default(0) @map("working_days_in_period")
  absentDays           Float          @default(0) @map("absent_days")
  absentDeduction      Int            @default(0) @map("absent_deduction")
  holidayWorkDays      Int            @default(0) @map("holiday_work_days")
  // アルバイト・業務委託用
  totalWorkHours       Float          @default(0) @map("total_work_hours")
  // 共通控除
  healthInsurance      Int            @default(0) @map("health_insurance")
  pensionInsurance     Int            @default(0) @map("pension_insurance")
  employmentInsurance  Int            @default(0) @map("employment_insurance")
  incomeTax            Int            @default(0) @map("income_tax")
  residentTax          Int            @default(0) @map("resident_tax")
  // 経費精算
  expenseTotal         Int            @default(0) @map("expense_total")
  // 合計
  grossPay             Int            @map("gross_pay")
  totalDeductions      Int            @map("total_deductions")
  netPay               Int            @map("net_pay")
  status               PayrollStatus  @default(DRAFT)
  note                 String?        @db.Text
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @default(now()) @updatedAt @map("updated_at")

  @@unique([employeeId, periodStart, periodEnd])
  @@map("payroll_records")
}

// ==========================================
// 配布員 給与計算モジュール
// ==========================================

// --- 給与明細ステータス ---
enum DistributorPayrollStatus {
  DRAFT      @map("下書き")
  CONFIRMED  @map("確定済")
  PAID       @map("支払済")
}

// --- 配布員週次給与レコード ---
model DistributorPayrollRecord {
  id            Int                       @id @default(autoincrement())
  distributorId Int                       @map("distributor_id")
  distributor   FlyerDistributor          @relation(fields: [distributorId], references: [id], onDelete: Cascade)

  periodStart   DateTime                  @map("period_start") @db.Date  // 日曜日
  periodEnd     DateTime                  @map("period_end") @db.Date    // 土曜日
  paymentDate   DateTime                  @map("payment_date") @db.Date  // 翌週金曜日

  schedulePay   Int                       @default(0) @map("schedule_pay")  // 配布報酬合計
  expensePay    Int                       @default(0) @map("expense_pay")   // 交通費合計
  grossPay      Int                       @default(0) @map("gross_pay")     // 支給合計

  status        DistributorPayrollStatus  @default(DRAFT)
  note          String?                   @db.Text

  items         DistributorPayrollItem[]

  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  @@unique([distributorId, periodStart])
  @@map("distributor_payroll_records")
}

// --- 配布員給与明細行（スケジュール単位）---
model DistributorPayrollItem {
  id             Int                      @id @default(autoincrement())
  payrollId      Int                      @map("payroll_id")
  payroll        DistributorPayrollRecord @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  date           DateTime                 @db.Date
  scheduleId     Int?                     @map("schedule_id")  // DistributionSchedule.id

  flyerTypeCount Int                      @map("flyer_type_count")   // チラシ種類数 n (1〜6)
  baseRate       Float                    @map("base_rate")          // rate_n_type の値
  areaUnitPrice  Float                    @default(0) @map("area_unit_price")
  sizeUnitPrice  Float                    @default(0) @map("size_unit_price")
  unitPrice      Float                    @map("unit_price")         // baseRate + area + size
  actualCount    Int                      @default(0) @map("actual_count")  // 投函ポスト数
  earnedAmount   Int                      @default(0) @map("earned_amount") // unitPrice × actualCount (切り捨て)

  createdAt      DateTime                 @default(now()) @map("created_at")

  @@map("distributor_payroll_items")
}

model Notification {
  id         Int      @id @default(autoincrement())
  
  customerId Int      @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  orderId    Int?     @map("order_id")
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  title      String   @db.VarChar(200)
  message    String   @db.Text
  type       String   @default("INFO") @db.VarChar(50) // INFO, ACTION_REQUIRED, SUCCESS など
  isRead     Boolean  @default(false) @map("is_read")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}

// ==========================================
// CRM モジュール
// ==========================================

model CustomerActivity {
  id         Int       @id @default(autoincrement())
  customerId Int       @map("customer_id")
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  employeeId Int?      @map("employee_id")
  employee   Employee? @relation("ActivityEmployee", fields: [employeeId], references: [id])
  type       String    @db.VarChar(20)    // CALL, VISIT, EMAIL, ONLINE, NOTE
  subject    String    @db.VarChar(200)
  body       String?   @db.Text
  activityAt DateTime  @map("activity_at")
  nextAction String?   @map("next_action") @db.VarChar(200)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@map("customer_activities")
}

// --- タスク種類マスタ ---
model TaskCategoryMaster {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)   // 表示名（例: 営業, 現場, アドミン）
  code      String   @unique @db.VarChar(20) // コード（例: SALES, FIELD, ADMIN）
  icon      String?  @db.VarChar(50)   // Bootstrap icon class
  colorCls  String?  @map("color_cls") @db.VarChar(100) // Tailwind CSS classes
  sortOrder Int      @default(100) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks         Task[]
  taskTemplates TaskTemplate[]

  @@map("task_category_masters")
}

enum RecurrenceType {
  ONCE    // 一回のみ
  DAILY   // 毎日
  WEEKLY  // 毎週
  MONTHLY // 毎月
  YEARLY  // 毎年
}

enum TaskCompletionRule {
  SHARED     // 1つのタスクを複数人で共有（誰か1人が完了すればOK）
  INDIVIDUAL // 担当者ごとに独立タスクを生成
}

model Task {
  id             Int               @id @default(autoincrement())
  customerId     Int?              @map("customer_id")
  customer       Customer?         @relation(fields: [customerId], references: [id])
  distributorId  Int?              @map("distributor_id")
  distributor    FlyerDistributor? @relation(fields: [distributorId], references: [id])
  assigneeId     Int?              @map("assignee_id")
  assignee       Employee?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdById    Int?              @map("created_by_id")
  createdBy      Employee?         @relation("TaskCreator", fields: [createdById], references: [id])
  title          String            @db.VarChar(200)
  description    String?           @db.Text
  dueDate        DateTime          @map("due_date")
  priority       String            @default("MEDIUM") @db.VarChar(10)  // LOW, MEDIUM, HIGH
  status         String            @default("PENDING") @db.VarChar(20) // PENDING, IN_PROGRESS, DONE
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  // --- 追加フィールド ---
  categoryId     Int?              @map("category_id")
  taskCategory   TaskCategoryMaster? @relation(fields: [categoryId], references: [id])
  branchId       Int?              @map("branch_id")
  branch         Branch?           @relation("TaskBranch", fields: [branchId], references: [id])
  scheduleId     Int?              @map("schedule_id")
  schedule       DistributionSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  templateId     Int?              @map("template_id")
  template       TaskTemplate?     @relation(fields: [templateId], references: [id])

  // クレーム紐付け
  complaintId    Int?              @map("complaint_id")
  complaint      Complaint?        @relation(fields: [complaintId], references: [id])

  // 複数担当者
  assignees      TaskAssignee[]

  @@index([categoryId])
  @@index([templateId])
  @@index([complaintId])
  @@map("tasks")
}

// --- タスク×担当者 中間テーブル ---
model TaskAssignee {
  id           Int          @id @default(autoincrement())
  taskId       Int          @map("task_id")
  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId   Int?         @map("employee_id")
  employee     Employee?    @relation("TaskAssigneeEmployee", fields: [employeeId], references: [id])
  departmentId Int?         @map("department_id")
  department   Department?  @relation(fields: [departmentId], references: [id])
  branchId     Int?         @map("branch_id")
  branch       Branch?      @relation("TaskAssigneeBranch", fields: [branchId], references: [id])

  @@unique([taskId, employeeId, departmentId, branchId])
  @@map("task_assignees")
}

// --- 定期タスクテンプレート ---
model TaskTemplate {
  id               Int                @id @default(autoincrement())
  title            String             @db.VarChar(200)
  description      String?            @db.Text
  categoryId       Int?               @map("category_id")
  taskCategory     TaskCategoryMaster? @relation(fields: [categoryId], references: [id])
  priority         String             @default("MEDIUM") @db.VarChar(10)
  completionRule   TaskCompletionRule @default(SHARED) @map("completion_rule")

  // 紐付け（カテゴリに応じて使い分け）
  customerId       Int?               @map("customer_id")
  customer         Customer?          @relation(fields: [customerId], references: [id])
  distributorId    Int?               @map("distributor_id")
  distributor      FlyerDistributor?  @relation(fields: [distributorId], references: [id])
  branchId         Int?               @map("branch_id")
  branch           Branch?            @relation("TaskTemplateBranch", fields: [branchId], references: [id])
  scheduleId       Int?               @map("schedule_id")
  schedule         DistributionSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  // サイクル設定
  recurrenceType   RecurrenceType     @default(ONCE) @map("recurrence_type")
  recurrenceValue  String?            @map("recurrence_value") @db.VarChar(100)
  dueTime          String?            @map("due_time") @db.VarChar(5) // "HH:MM" 形式

  // 担当者設定（JSON配列）
  targetEmployeeIds   Json?  @map("target_employee_ids")
  targetDepartmentIds Json?  @map("target_department_ids")
  targetBranchIds     Json?  @map("target_branch_ids")

  // 制御
  isActive         Boolean  @default(true) @map("is_active")
  lastGeneratedAt  DateTime? @map("last_generated_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // 生成されたタスクへの逆参照
  tasks            Task[]

  @@map("task_templates")
}

// ==========================================
// キャンペーン管理
// ==========================================

model Campaign {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(100)
  description String?   @db.Text
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  customers Customer[]
  leads     Lead[]

  @@map("campaigns")
}

// ==========================================
// 見込み客（リード）管理
// ==========================================

model Lead {
  id           Int     @id @default(autoincrement())
  name         String  @db.VarChar(100)
  nameKana     String? @map("name_kana") @db.VarChar(100)
  contactName  String? @map("contact_name") @db.VarChar(50)
  contactEmail String? @map("contact_email") @db.VarChar(255)
  phone        String? @db.VarChar(20)
  postalCode   String? @map("postal_code") @db.VarChar(8)
  address      String? @db.VarChar(255)

  stage              LeadStage           @default(APPROACH)
  acquisitionChannel AcquisitionChannel? @map("acquisition_channel")
  salesRepId         Int?                @map("sales_rep_id")
  campaignId         Int?                @map("campaign_id")

  note              String?   @db.Text
  nextAction        String?   @map("next_action") @db.VarChar(255)
  expectedCloseDate DateTime? @map("expected_close_date")

  convertedCustomerId Int?      @map("converted_customer_id")
  convertedAt         DateTime? @map("converted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salesRep          Employee? @relation(fields: [salesRepId], references: [id])
  campaign          Campaign? @relation(fields: [campaignId], references: [id])
  convertedCustomer Customer? @relation("LeadConversion", fields: [convertedCustomerId], references: [id])

  @@map("leads")
}

// --- 全体お知らせカテゴリ (Enum) ---
enum AnnouncementCategory {
  UPDATE      // アップデート
  MAINTENANCE // メンテナンス
  IMPORTANT   // 重要
  NOTICE      // お知らせ
  OTHER       // その他
}

// --- 全体お知らせ ---
model Announcement {
  id          Int                  @id @default(autoincrement())
  title       String               @db.VarChar(255)
  content     String               @db.Text
  category    AnnouncementCategory @default(OTHER)
  isBlocking  Boolean              @default(false) @map("is_blocking")
  createdById Int                  @map("created_by_id")
  createdBy   Employee             @relation(fields: [createdById], references: [id])
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  reads       AnnouncementRead[]

  @@map("announcements")
}

model AnnouncementRead {
  id             Int          @id @default(autoincrement())
  announcementId Int          @map("announcement_id")
  employeeId     Int          @map("employee_id")
  readAt         DateTime     @default(now()) @map("read_at")
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  employee       Employee     @relation(fields: [employeeId], references: [id])

  @@unique([announcementId, employeeId])
  @@map("announcement_reads")
}

// ─────────────────────────────────────────────
// 帳票管理
// ─────────────────────────────────────────────

enum DocumentType {
  ESTIMATE  // 見積書
  INVOICE   // 請求書
  DELIVERY  // 納品書
  RECEIPT   // 領収書
}

// 自社情報（発行元設定）: 常に1レコードのみ
model CompanySetting {
  id                        Int      @id @default(autoincrement())
  companyName               String   @db.VarChar(100) @map("company_name")
  companyNameKana           String?  @db.VarChar(100) @map("company_name_kana")
  postalCode                String?  @db.VarChar(10)  @map("postal_code")
  address                   String?  @db.Text
  phone                     String?  @db.VarChar(20)
  fax                       String?  @db.VarChar(20)
  email                     String?  @db.VarChar(100)
  website                   String?  @db.VarChar(200)
  invoiceRegistrationNumber String?  @db.VarChar(14)  @map("invoice_registration_number")
  bankName                  String?  @db.VarChar(50)  @map("bank_name")
  bankBranch                String?  @db.VarChar(50)  @map("bank_branch")
  bankAccountType           String?  @db.VarChar(10)  @map("bank_account_type")
  bankAccountNumber         String?  @db.VarChar(20)  @map("bank_account_number")
  bankAccountHolder         String?  @db.VarChar(100) @map("bank_account_holder")
  logoUrl                   String?  @db.Text         @map("logo_url")
  representativeName        String?  @db.VarChar(100) @map("representative_name")
  sealImageUrl              String?  @db.Text         @map("seal_image_url")
  updatedAt                 DateTime @updatedAt       @map("updated_at")

  @@map("company_settings")
}

// 帳票発行履歴
model Document {
  id           Int          @id @default(autoincrement())
  orderId      Int          @map("order_id")
  order        Order        @relation(fields: [orderId], references: [id])
  documentType DocumentType @map("document_type")
  documentNo   String       @unique @map("document_no") @db.VarChar(30)
  issuedAt     DateTime     @default(now())            @map("issued_at")
  subtotal     Int          @default(0)
  taxAmount    Int          @default(0)                @map("tax_amount")
  totalAmount  Int          @default(0)                @map("total_amount")
  note            String?      @db.Text
  paymentDueDate  DateTime?                            @map("payment_due_date")
  createdAt       DateTime     @default(now())         @map("created_at")
  updatedAt    DateTime     @updatedAt                 @map("updated_at")

  @@map("documents")
}

// ==========================================
// 月次まとめ請求（BillingStatement）
// ==========================================

enum BillingStatus {
  DRAFT      // 下書き（作成後、確定前）
  CONFIRMED  // 確定済み（営業マンが確認・ロック）
  SENT       // 請求書を顧客に送付済み
  PAID       // 入金済み
}

// 月次まとめ請求ヘッダー（1顧客×1請求月に対して1レコード）
model BillingStatement {
  id            Int                    @id @default(autoincrement())
  statementNo   String                 @unique @map("statement_no") @db.VarChar(30)
  customerId    Int                    @map("customer_id")
  customer      Customer               @relation(fields: [customerId], references: [id])
  billingMonth  String                 @map("billing_month") @db.VarChar(7) // "2026-02"
  status        BillingStatus          @default(DRAFT)
  subtotal      Int                    @default(0)
  taxAmount     Int                    @default(0)  @map("tax_amount")
  totalAmount   Int                    @default(0)  @map("total_amount")
  note          String?                @db.Text
  paymentDueDate DateTime?             @map("payment_due_date")
  confirmedAt   DateTime?              @map("confirmed_at")
  sentAt        DateTime?              @map("sent_at")
  paidAt        DateTime?              @map("paid_at")
  paymentMethod String?                @map("payment_method") @db.VarChar(50)
  items         BillingStatementItem[]
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt     @map("updated_at")

  @@map("billing_statements")
}

// まとめ請求の明細行（受注と1:1）
model BillingStatementItem {
  id                 Int              @id @default(autoincrement())
  billingStatementId Int              @map("billing_statement_id")
  billingStatement   BillingStatement @relation(fields: [billingStatementId], references: [id], onDelete: Cascade)
  orderId            Int              @unique @map("order_id")
  order              Order            @relation(fields: [orderId], references: [id])
  subtotal           Int              @default(0)
  taxAmount          Int              @default(0)  @map("tax_amount")
  amount             Int              @default(0)

  @@map("billing_statement_items")
}

// ==========================================
// 監査ログ
// ==========================================

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  STATUS_CHANGE
}

enum AuditActorType {
  EMPLOYEE
  PORTAL_USER
  STAFF
  SYSTEM
}

model AuditLog {
  id          Int            @id @default(autoincrement())
  actorType   AuditActorType @map("actor_type")
  actorId     Int?           @map("actor_id")
  actorName   String?        @map("actor_name") @db.VarChar(100)
  action      AuditAction
  targetModel String?        @map("target_model") @db.VarChar(50)
  targetId    Int?           @map("target_id")
  beforeData  Json?          @map("before_data")
  afterData   Json?          @map("after_data")
  ipAddress   String?        @map("ip_address") @db.VarChar(45)
  userAgent   String?        @map("user_agent") @db.VarChar(500)
  description String?        @db.VarChar(500)
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([actorId, actorType])
  @@index([targetModel, targetId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ==========================================
// 応募者管理・面接日程調整
// ==========================================

enum ApplicantFlowStatus {
  INTERVIEW_WAITING  @map("面接待ち")
  NO_SHOW            @map("面接不参加")
  CANCELLED          @map("キャンセル")
  TRAINING_WAITING   @map("研修待ち")
  TRAINING_COMPLETED @map("研修完了")
}

enum ApplicantHiringStatus {
  IN_PROGRESS @map("選考中")
  HIRED       @map("採用")
  REJECTED    @map("不採用")
}

// --- 面接方法 ---
enum MeetingType {
  GOOGLE_MEET
  ZOOM
}

// --- 面接スロットマスタ ---
model InterviewSlotMaster {
  id                Int         @id @default(autoincrement())
  name              String      @db.VarChar(100)
  meetingType       MeetingType @default(GOOGLE_MEET) @map("meeting_type")
  zoomUrl           String?     @map("zoom_url") @db.VarChar(500)
  zoomMeetingNumber String?     @map("zoom_meeting_number") @db.VarChar(50)
  zoomPassword      String?     @map("zoom_password") @db.VarChar(50)
  capacity          Int         @default(1)
  allowHolidays     Boolean     @default(true) @map("allow_holidays")
  isActive          Boolean     @default(true) @map("is_active")
  sortOrder         Int         @default(100) @map("sort_order")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  jobCategories         JobCategory[]
  defaultInterviewSlots DefaultInterviewSlot[]
  interviewSlots        InterviewSlot[]

  @@map("interview_slot_masters")
}

// --- 応募職種マスタ ---
model JobCategory {
  id        Int      @id @default(autoincrement())
  nameJa    String   @map("name_ja") @db.VarChar(100)
  nameEn    String?  @map("name_en") @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(100) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  interviewSlotMasterId Int?               @map("interview_slot_master_id")
  interviewSlotMaster   InterviewSlotMaster? @relation(fields: [interviewSlotMasterId], references: [id])

  applicants     Applicant[]
  interviewSlots InterviewSlot[]

  @@map("job_categories")
}

// --- 面接スロット ---
model InterviewSlot {
  id        Int      @id @default(autoincrement())
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  isBooked  Boolean  @default(false) @map("is_booked")
  meetUrl           String?  @map("meet_url") @db.VarChar(500)
  calendarEventId   String?  @map("calendar_event_id") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 1:1 with Applicant (optional)

  // 職種（nullの場合は全職種対応）
  jobCategoryId Int?         @map("job_category_id")
  jobCategory   JobCategory? @relation(fields: [jobCategoryId], references: [id])

  applicantId Int?       @unique @map("applicant_id")
  applicant   Applicant? @relation(fields: [applicantId], references: [id])

  // 面接スロットマスタ
  interviewSlotMasterId Int?               @map("interview_slot_master_id")
  interviewSlotMaster   InterviewSlotMaster? @relation(fields: [interviewSlotMasterId], references: [id])

  // 面接担当者
  interviewerId Int?      @map("interviewer_id")
  interviewer   Employee? @relation("InterviewerSlots", fields: [interviewerId], references: [id])

  // 複数人予約対応（中間テーブル）
  interviewSlotApplicants InterviewSlotApplicant[]

  @@index([startTime])
  @@index([isBooked])
  @@index([jobCategoryId])
  @@index([interviewerId])
  @@index([interviewSlotMasterId])
  @@map("interview_slots")
}

// --- 面接スロット×応募者 中間テーブル（複数人予約対応） ---
model InterviewSlotApplicant {
  id              Int       @id @default(autoincrement())
  interviewSlotId Int       @map("interview_slot_id")
  applicantId     Int       @map("applicant_id")
  meetUrl         String?   @map("meet_url") @db.VarChar(500)
  calendarEventId String?   @map("calendar_event_id") @db.VarChar(500)
  bookedAt        DateTime  @default(now()) @map("booked_at")

  interviewSlot   InterviewSlot @relation(fields: [interviewSlotId], references: [id], onDelete: Cascade)
  applicant       Applicant     @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([interviewSlotId, applicantId])
  @@index([applicantId])
  @@map("interview_slot_applicants")
}

// --- カスタム祝日 ---
model CustomHoliday {
  id   Int      @id @default(autoincrement())
  date DateTime @unique @db.Date
  name String   @db.VarChar(100)

  @@map("custom_holidays")
}

// --- 応募者 ---
model Applicant {
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar(100)
  email    String  @unique @db.VarChar(255)
  phone    String? @db.VarChar(20)
  language String  @default("ja") @db.VarChar(5)

  // 職種
  jobCategoryId Int         @map("job_category_id")
  jobCategory   JobCategory @relation(fields: [jobCategoryId], references: [id])

  // 国籍
  countryId Int?     @map("country_id")
  country   Country? @relation(fields: [countryId], references: [id])

  // 在留資格
  visaTypeId Int?      @map("visa_type_id")
  visaType   VisaType? @relation(fields: [visaTypeId], references: [id])

  // 生年月日
  birthday DateTime? @db.Date

  // 性別
  gender Gender @default(unknown)

  // 住所
  postalCode String? @map("postal_code") @db.VarChar(8)
  address    String? @db.Text
  building   String? @db.VarChar(200)

  // 面接管理トークン（変更・キャンセル用）
  managementToken String? @unique @map("management_token") @db.VarChar(64)

  // 求人媒体
  recruitingMediaId Int?              @map("recruiting_media_id")
  recruitingMedia   RecruitingMedia?  @relation(fields: [recruitingMediaId], references: [id])

  // 面接スロット (1:1 逆参照) — レガシー、Phase 5で削除予定
  interviewSlot InterviewSlot?

  // 複数人予約対応（中間テーブル）
  interviewSlotApplicants InterviewSlotApplicant[]

  // 研修スロット (多対1: 同じ研修枠に複数人参加可)
  trainingSlotId Int?           @map("training_slot_id")
  trainingSlot   TrainingSlot?  @relation(fields: [trainingSlotId], references: [id])

  // ステータス
  flowStatus    ApplicantFlowStatus   @default(INTERVIEW_WAITING) @map("flow_status")
  hiringStatus  ApplicantHiringStatus @default(IN_PROGRESS) @map("hiring_status")
  cancelReason  String?               @map("cancel_reason") @db.VarChar(100)

  // 面接評価項目
  hasOtherJob        Boolean? @map("has_other_job")
  otherJobDetails    String?  @map("other_job_details") @db.Text
  hasBankInJapan     Boolean? @map("has_bank_in_japan")
  japaneseLevel      Int?     @map("japanese_level")
  englishLevel       Int?     @map("english_level")
  communicationScore Int?     @map("communication_score")
  impressionScore    Int?     @map("impression_score")
  interviewNotes     String?  @map("interview_notes") @db.Text

  // 研修評価項目
  trainingAttendance       String?  @map("training_attendance") @db.VarChar(20) // ATTENDED / NO_SHOW
  trainingUnderstandingScore Int?   @map("training_understanding_score") // 理解度 1-5
  trainingCommunicationScore Int?   @map("training_communication_score") // コミュニケーション 1-5
  trainingSpeedScore         Int?   @map("training_speed_score") // スピード 1-5
  trainingMotivationScore    Int?   @map("training_motivation_score") // やる気 1-5
  trainingNotes              String? @map("training_notes") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([flowStatus])
  @@index([hiringStatus])
  @@index([createdAt])
  @@map("applicants")
}
// --- 研修スロット ---
model TrainingSlot {
  id        Int      @id @default(autoincrement())
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  capacity  Int      @default(10) @map("capacity") // 定員（グループ研修）
  location  String?  @db.VarChar(200)              // 研修場所
  note      String?  @db.Text                       // 備考
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 多対1 逆参照: 複数応募者が同じ研修枠を予約可
  applicants Applicant[]

  @@index([startTime])
  @@map("training_slots")
}

// --- デフォルト研修スロット設定（曜日ごと） ---
model DefaultTrainingSlot {
  id              Int      @id @default(autoincrement())
  dayOfWeek       Int      @map("day_of_week") // 0=日曜, 1=月曜, ..., 6=土曜
  startTime       String   @map("start_time") @db.VarChar(5) // "09:00" 形式
  endTime         String   @map("end_time") @db.VarChar(5)   // "17:00" 形式
  intervalMinutes Int      @default(120) @map("interval_minutes") // 研修時間（分）
  capacity        Int      @default(10) @map("capacity")          // デフォルト定員
  isEnabled       Boolean  @default(true) @map("is_enabled")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([dayOfWeek])
  @@map("default_training_slots")
}

// --- 求人媒体マスタ ---
model RecruitingMedia {
  id        Int      @id @default(autoincrement())
  nameJa    String   @map("name_ja") @db.VarChar(100)
  nameEn    String?  @map("name_en") @db.VarChar(100)
  code      String   @unique @db.VarChar(50) // URLパラメータ値: "indeed", "mynavi" 等
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(100) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  applicants Applicant[]

  @@map("recruiting_media")
}

// --- デフォルト面接スロット設定（曜日ごと） ---
model DefaultInterviewSlot {
  id              Int      @id @default(autoincrement())
  dayOfWeek       Int      @map("day_of_week") // 0=日曜, 1=月曜, ..., 6=土曜
  startTime       String   @map("start_time") @db.VarChar(5) // "09:00" 形式
  endTime         String   @map("end_time") @db.VarChar(5)   // "17:00" 形式
  intervalMinutes Int      @default(60) @map("interval_minutes")
  isEnabled       Boolean  @default(true) @map("is_enabled")
  interviewerId   Int?     @map("interviewer_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // マスタ
  interviewSlotMasterId Int @map("interview_slot_master_id")
  interviewSlotMaster   InterviewSlotMaster @relation(fields: [interviewSlotMasterId], references: [id], onDelete: Cascade)

  // リレーション
  interviewer   Employee? @relation("DefaultSlotInterviewer", fields: [interviewerId], references: [id])

  @@unique([interviewSlotMasterId, dayOfWeek])
  @@map("default_interview_slots")
}


// ================================================================
// クレーム管理 + 配布禁止物件DB
// ================================================================

enum ResidenceCardVerificationStatus {
  PENDING
  VERIFIED
  MISMATCH
  ERROR
}

enum ComplaintStatus {
  UNRESOLVED    // 未対応
  IN_PROGRESS   // 対応中
  RESOLVED      // 解決済み
}

// --- 現地確認関連 Enum ---
enum InspectionCategory {
  CHECK      // チェック（配布確認）
  GUIDANCE   // 指導（配布指導）
}

enum FraudType {
  DISPOSAL
  SKIP
  FALSIFICATION
  OTHER
}

enum ComplaintSource {
  CUSTOMER    // 顧客
  RESIDENT    // 住人
  MANAGER     // 管理人
  PARTNER     // 外注先
  OTHER       // その他
}

// --- 禁止理由マスタ ---
model ProhibitedReason {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  sortOrder Int      @default(100) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  prohibitedProperties ProhibitedProperty[]

  @@map("prohibited_reasons")
}

// --- クレーム種別マスタ ---
model ComplaintType {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  penaltyScore Int      @default(10) @map("penalty_score") // デフォルト減点（正の整数）
  sortOrder    Int      @default(100) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  complaints Complaint[]

  @@map("complaint_types")
}

// --- 配布禁止物件 ---
model ProhibitedProperty {
  id                   Int       @id @default(autoincrement())

  // 物件特定情報
  prefectureId         Int?      @map("prefecture_id")
  cityId               Int?      @map("city_id")
  areaId               Int?      @map("area_id")
  postalCode           String?   @map("postal_code") @db.VarChar(8)
  address              String    @db.VarChar(500)
  buildingName         String?   @map("building_name") @db.VarChar(200)
  roomNumber           String?   @map("room_number") @db.VarChar(50)
  residentName         String?   @map("resident_name") @db.VarChar(100)

  // 座標
  latitude             Float?
  longitude            Float?

  // ポリゴン情報（polyline → GeoJSON変換後保存）
  boundaryGeojson      String?   @map("boundary_geojson") @db.LongText

  // 配布可能枚数（禁止前のポスト数。エリア配布可能数の減算に使用）
  unitCount            Int?      @map("unit_count")

  // 顧客限定禁止（null = 全顧客禁止）
  customerId           Int?      @map("customer_id")

  // 重要度（1=低 〜 5=最高。誤配時のリスクレベル）
  severity             Int?      @default(3)

  // 禁止理由
  prohibitedReasonId   Int?      @map("prohibited_reason_id")
  reasonDetail         String?   @map("reason_detail") @db.Text

  // CSVからの情報
  originalCode         String?   @map("original_code") @db.VarChar(50)
  externalCustomerCode String?   @map("external_customer_code") @db.VarChar(20)

  // 画像（S3 URL、JSON配列）
  imageUrls            String?   @map("image_urls") @db.Text

  // 状態管理
  isActive             Boolean   @default(true) @map("is_active")
  deactivatedAt        DateTime? @map("deactivated_at")
  deactivateReason     String?   @map("deactivate_reason") @db.Text

  // 登録元クレーム
  complaintId          Int?      @map("complaint_id")

  // CSVインポート日時
  importedAt           DateTime? @map("imported_at")

  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // リレーション
  prefecture       Prefecture?       @relation(fields: [prefectureId], references: [id])
  city             City?             @relation(fields: [cityId], references: [id])
  area             Area?             @relation(fields: [areaId], references: [id])
  customer         Customer?         @relation(fields: [customerId], references: [id])
  prohibitedReason ProhibitedReason? @relation(fields: [prohibitedReasonId], references: [id])
  complaint        Complaint?        @relation(fields: [complaintId], references: [id])
  skipEvents       SkipEvent[]

  @@index([areaId, isActive])
  @@index([customerId])
  @@map("prohibited_properties")
}

// --- クレーム ---
model Complaint {
  id              Int              @id @default(autoincrement())

  // 発生情報
  occurredAt      DateTime         @map("occurred_at") @db.Date
  receivedAt      DateTime         @default(now()) @map("received_at")

  // 種別
  complaintTypeId Int?             @map("complaint_type_id")

  // 対象
  customerId      Int?             @map("customer_id")
  distributorId   Int?             @map("distributor_id")
  scheduleId      Int?             @map("schedule_id")
  branchId        Int?             @map("branch_id")

  // 物件情報
  address         String           @db.VarChar(500)
  buildingName    String?          @map("building_name") @db.VarChar(200)
  roomNumber      String?          @map("room_number") @db.VarChar(50)
  latitude        Float?
  longitude       Float?

  // クレーム内容
  title           String           @db.VarChar(200)
  description     String           @db.Text

  // クレーム元
  source              ComplaintSource?
  sourceContactName   String?          @map("source_contact_name") @db.VarChar(100)
  sourceContactPhone  String?          @map("source_contact_phone") @db.VarChar(20)
  sourcePartnerId     Int?             @map("source_partner_id")

  // タスク連携チェック
  needsResponse       Boolean          @default(false) @map("needs_response")
  needsCustomerReport Boolean          @default(false) @map("needs_customer_report")

  // 対応状況
  status          ComplaintStatus  @default(UNRESOLVED)
  assigneeId      Int?             @map("assignee_id")

  // 画像
  imageUrls       String?          @map("image_urls") @db.Text

  // 個別減点スコア（null = ComplaintType のデフォルトを使用）
  penaltyScore    Int?             @map("penalty_score")

  // 不正行為フラグ
  isFraud         Boolean          @default(false) @map("is_fraud")
  fraudType       FraudType?       @map("fraud_type")

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // リレーション
  complaintType        ComplaintType?        @relation(fields: [complaintTypeId], references: [id])
  customer             Customer?             @relation(fields: [customerId], references: [id])
  distributor          FlyerDistributor?     @relation(fields: [distributorId], references: [id])
  schedule             DistributionSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  branch               Branch?               @relation(fields: [branchId], references: [id])
  assignee             Employee?             @relation("ComplaintAssignee", fields: [assigneeId], references: [id])
  sourcePartner        Partner?              @relation(fields: [sourcePartnerId], references: [id])

  responses            ComplaintResponse[]
  prohibitedProperties ProhibitedProperty[]
  tasks                Task[]

  @@index([status, createdAt])
  @@index([distributorId])
  @@index([customerId])
  @@index([scheduleId])
  @@map("complaints")
}

// --- クレーム対応履歴 ---
model ComplaintResponse {
  id          Int      @id @default(autoincrement())
  complaintId Int      @map("complaint_id")
  responderId Int?     @map("responder_id")
  content     String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  responder Employee? @relation("ComplaintResponder", fields: [responderId], references: [id])

  @@map("complaint_responses")
}

// --- 評価期間 ---
enum EvaluationPeriod {
  WEEKLY
}

// --- 配布員評価 ---
model DistributorEvaluation {
  id               Int              @id @default(autoincrement())
  distributorId    Int              @map("distributor_id")
  distributor      FlyerDistributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)

  periodStart      DateTime         @map("period_start") @db.Date
  periodEnd        DateTime         @map("period_end") @db.Date

  performanceScore Int              @map("performance_score") // 稼働実績スコア（加点分）
  qualityScore     Int              @map("quality_score")     // 品質スコア（減点分、負の値）
  totalScore       Int              @map("total_score")       // baseScore + performance + quality
  determinedRank   String           @map("determined_rank") @db.VarChar(10)

  // 内訳詳細（JSON）
  scoreBreakdown   String?          @map("score_breakdown") @db.Text

  note             String?          @db.Text
  isManualOverride Boolean          @default(false) @map("is_manual_override")

  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@unique([distributorId, periodStart])
  @@map("distributor_evaluations")
}

// --- 現場巡回記録 ---
model FieldInspection {
  id              Int                @id @default(autoincrement())
  distributorId   Int                @map("distributor_id")
  distributor     FlyerDistributor   @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  inspectorId     Int                @map("inspector_id")
  inspector       Employee           @relation(fields: [inspectorId], references: [id])
  scheduleId      Int?               @map("schedule_id")

  inspectedAt     DateTime           @map("inspected_at")
  category        InspectionCategory @default(CHECK)

  // === チェック項目 ===
  coverageChecked       Int?         @map("coverage_checked")       // 確認件数
  coverageFound         Int?         @map("coverage_found")         // チラシ確認件数
  prohibitedTotal       Int?         @map("prohibited_total")       // 禁止物件数
  prohibitedViolations  Int?         @map("prohibited_violations")  // 禁止物件投函数
  multipleInsertion     String?      @map("multiple_insertion") @db.VarChar(20)  // NONE/MINOR/SOME/MANY
  fraudTrace            String?      @map("fraud_trace") @db.VarChar(20)         // NONE/SUSPICIOUS/FOUND

  // === 指導項目 ===
  distributionSpeed     String?      @map("distribution_speed") @db.VarChar(20)    // VERY_SLOW/SLOW/NORMAL/FAST/VERY_FAST
  stickerCompliance     String?      @map("sticker_compliance") @db.VarChar(20)    // NO_MISTAKES/SOME/MANY
  prohibitedCompliance  String?      @map("prohibited_compliance") @db.VarChar(20) // NO_MISTAKES/SOME/MANY
  mapComprehension      String?      @map("map_comprehension") @db.VarChar(20)     // BAD/NORMAL/GOOD
  workAttitude          String?      @map("work_attitude") @db.VarChar(20)         // BAD/NORMAL/GOOD

  // 共通
  note               String?         @db.Text
  followUpRequired   Boolean         @default(false) @map("follow_up_required")

  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@index([distributorId, inspectedAt])
  @@map("field_inspections")
}

// ==========================================
// アプリ配信ログ（TestFlight / Android ベータ招待）
// ==========================================

enum AppDistributionPlatform {
  APPLE     // TestFlight (iOS)
  ANDROID   // Google Play (Android)
}

enum AppDistributionStatus {
  PENDING   // 送信中
  SENT      // 送信完了
  FAILED    // 送信失敗
}

model AppDistributionLog {
  id             Int                       @id @default(autoincrement())
  distributorId  Int                       @map("distributor_id")
  platform       AppDistributionPlatform
  email          String                    @db.VarChar(100)
  status         AppDistributionStatus     @default(PENDING)
  errorMessage   String?                   @map("error_message") @db.Text
  sentAt         DateTime?                 @map("sent_at")
  sentById       Int?                      @map("sent_by_id")
  createdAt      DateTime                  @default(now()) @map("created_at")

  distributor    FlyerDistributor          @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  sentBy         Employee?                 @relation("AppDistributionSender", fields: [sentById], references: [id])

  @@index([distributorId])
  @@index([platform, status])
  @@map("app_distribution_logs")
}

// ============================================================
// GPS トラッキング関連
// ============================================================

// --- 配布作業セッション（START〜FINISH） ---
model DistributionSession {
  id              Int                @id @default(autoincrement())
  scheduleId      Int?               @unique @map("schedule_id")
  distributorId   Int                @map("distributor_id")

  startedAt       DateTime           @map("started_at")
  finishedAt      DateTime?          @map("finished_at")

  // フィットネス集計
  totalSteps      Int                @default(0) @map("total_steps")
  totalDistance    Float              @default(0) @map("total_distance")   // メートル
  totalCalories   Float              @default(0) @map("total_calories")

  // 終了情報
  incompleteReason IncompleteReason? @map("incomplete_reason")
  incompleteNote   String?           @map("incomplete_note") @db.Text

  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  // リレーション
  schedule        DistributionSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  distributor     FlyerDistributor     @relation(fields: [distributorId], references: [id])
  gpsPoints       GpsPoint[]
  progressEvents  ProgressEvent[]
  skipEvents      SkipEvent[]
  pauseEvents     PauseEvent[]

  @@index([distributorId, startedAt])
  @@map("distribution_sessions")
}

// --- GPS座標（10秒ごとの高頻度データ） ---
model GpsPoint {
  id         Int      @id @default(autoincrement())
  sessionId  Int      @map("session_id")
  latitude   Float
  longitude  Float
  accuracy   Float?   // GPS精度（メートル）
  timestamp  DateTime // デバイス時刻

  // 累積フィットネスデータ（オプション）
  steps      Int?
  distance   Float?   // 累積メートル
  calories   Float?   // 累積カロリー

  createdAt  DateTime @default(now()) @map("created_at")

  session    DistributionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@map("gps_points")
}

// --- 進捗報告（500枚完了ごと） ---
model ProgressEvent {
  id           Int      @id @default(autoincrement())
  sessionId    Int      @map("session_id")
  mailboxCount Int      @map("mailbox_count") // 累積ポスト数
  latitude     Float?
  longitude    Float?
  timestamp    DateTime
  createdAt    DateTime @default(now()) @map("created_at")

  session      DistributionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@map("progress_events")
}

// --- 配布禁止物件スキップ記録 ---
model SkipEvent {
  id                    Int      @id @default(autoincrement())
  sessionId             Int      @map("session_id")
  latitude              Float
  longitude             Float
  prohibitedPropertyId  Int?     @map("prohibited_property_id")
  reason                String?  @db.Text
  timestamp             DateTime
  createdAt             DateTime @default(now()) @map("created_at")

  session              DistributionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  prohibitedProperty   ProhibitedProperty? @relation(fields: [prohibitedPropertyId], references: [id])

  @@index([sessionId])
  @@map("skip_events")
}

// --- 一時停止イベント ---
model PauseEvent {
  id         Int       @id @default(autoincrement())
  sessionId  Int       @map("session_id")
  pausedAt   DateTime  @map("paused_at")   // PAUSE した時刻
  resumedAt  DateTime? @map("resumed_at")  // RESUME した時刻（null = 現在停止中）
  createdAt  DateTime  @default(now()) @map("created_at")

  session    DistributionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("pause_events")
}

// --- 管理者通知 ---
model AdminNotification {
  id                  Int                    @id @default(autoincrement())
  type                AdminNotificationType
  title               String                 @db.VarChar(200)
  message             String?                @db.Text
  scheduleId          Int?                   @map("schedule_id")
  distributorId       Int?                   @map("distributor_id")
  recipientId         Int?                   @map("recipient_id")
  alertDefinitionId   Int?                   @map("alert_definition_id")
  alertId             Int?                   @map("alert_id")
  isRead              Boolean                @default(false) @map("is_read")
  createdAt           DateTime               @default(now()) @map("created_at")

  schedule            DistributionSchedule?  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  distributor         FlyerDistributor?      @relation(fields: [distributorId], references: [id])
  recipient           Employee?              @relation("NotificationRecipient", fields: [recipientId], references: [id])
  alertDefinition     AlertDefinition?       @relation(fields: [alertDefinitionId], references: [id])

  @@index([isRead, createdAt])
  @@index([recipientId, isRead, createdAt])
  @@map("admin_notifications")
}

// --- アラート重要度 ---
enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// --- アラートステータス ---
enum AlertStatus {
  OPEN
  RESOLVED
}

// --- アラートカテゴリマスタ ---
model AlertCategory {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  icon      String?  @db.VarChar(50)
  colorCls  String?  @map("color_cls") @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  alerts           Alert[]
  alertDefinitions AlertDefinition[]

  @@map("alert_categories")
}

// --- アラート ---
model Alert {
  id           Int            @id @default(autoincrement())
  categoryId   Int            @map("category_id")
  severity     AlertSeverity  @default(INFO)
  status       AlertStatus    @default(OPEN)
  title        String         @db.VarChar(255)
  message      String?        @db.Text
  entityType   String?        @map("entity_type") @db.VarChar(50)
  entityId     Int?           @map("entity_id")
  resolvedById Int?           @map("resolved_by_id")
  resolvedAt   DateTime?      @map("resolved_at")
  resolvedNote String?        @map("resolved_note") @db.Text
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at")

  category     AlertCategory  @relation(fields: [categoryId], references: [id])
  resolvedBy   Employee?      @relation("AlertResolver", fields: [resolvedById], references: [id])

  @@index([status, severity])
  @@index([categoryId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("alerts")
}

// --- アラート定義（設定可能なアラートルール） ---
model AlertDefinition {
  id              Int              @id @default(autoincrement())
  code            String           @unique @db.VarChar(50)
  name            String           @db.VarChar(100)
  description     String?          @db.Text

  isEnabled       Boolean          @default(true) @map("is_enabled")

  categoryId      Int              @map("category_id")
  category        AlertCategory    @relation(fields: [categoryId], references: [id])
  severity        AlertSeverity    @default(WARNING)
  frequency       AlertFrequency   @default(DAILY)

  // スケジュール詳細
  scheduleHour       Int            @default(9) @map("schedule_hour")          // 実行時刻（0-23、JST）
  scheduleDayOfWeek  Int?           @map("schedule_day_of_week")               // 曜日（0=日〜6=土）WEEKLY時
  scheduleDayOfMonth Int?           @map("schedule_day_of_month")              // 日付（1-31）MONTHLY時
  scheduleWeekOrdinal Int?          @map("schedule_week_ordinal")              // 第n週（1-5, -1=最後）MONTHLY時
  // MONTHLY: scheduleDayOfMonth指定 → 毎月n日、scheduleWeekOrdinal+scheduleDayOfWeek指定 → 毎月第n X曜日

  targetType      AlertTargetType  @default(ALL) @map("target_type")
  targetIds       String?          @map("target_ids") @db.Text

  notifyEnabled   Boolean          @default(true) @map("notify_enabled")

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  notifications   AdminNotification[]

  @@map("alert_definitions")
}

// ==========================================
// ピッキング照合モジュール
// ==========================================

// --- AI照合結果 ---
enum VerificationResult {
  MATCH     @map("一致")
  MISMATCH  @map("不一致")
  UNCERTAIN @map("要確認")
}

// --- 人的チェック結果 ---
enum CheckerResult {
  APPROVED @map("承認")
  REJECTED @map("差戻し")
}

// --- ピッキングステータス ---
enum PickingStatus {
  PENDING     @map("未着手")
  AI_CHECKED  @map("AI確認済")
  VERIFIED    @map("完了")
  REJECTED    @map("差戻し")
}

// --- ピッキング照合 ---
model PickingVerification {
  id           Int                  @id @default(autoincrement())
  
  // スケジュールとの紐付け（1スケジュール = 1レコード）
  scheduleId   Int                  @unique @map("schedule_id")
  schedule     DistributionSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  
  // 写真（S3）
  photoUrl     String?              @map("photo_url") @db.Text
  
  // ピッキング担当者
  pickerId     Int                  @map("picker_id")
  picker       Employee             @relation("PickingPicker", fields: [pickerId], references: [id])
  pickedAt     DateTime             @map("picked_at")
  
  // AI照合結果
  aiResult     VerificationResult?  @map("ai_result")
  aiReason     String?              @map("ai_reason") @db.Text
  aiCheckedAt  DateTime?            @map("ai_checked_at")
  
  // 人的チェック
  checkerId    Int?                 @map("checker_id")
  checker      Employee?            @relation("PickingChecker", fields: [checkerId], references: [id])
  checkerResult CheckerResult?      @map("checker_result")
  checkerNote  String?              @map("checker_note") @db.Text
  checkedAt    DateTime?            @map("checked_at")
  
  // ステータス
  status       PickingStatus        @default(PENDING)
  
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  
  @@index([pickerId])
  @@index([checkerId])
  @@index([status])
  @@map("picking_verifications")
}
